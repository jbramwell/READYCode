{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build ReadyCode",
            "command": "dotnet",
            "type": "process",
            "args": [
                "build",
                "${workspaceFolder}/ReadyCode/ReadyCode.csproj",
                "-c",
                "Debug"
            ],
            "problemMatcher": "$msCompile",
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "Run ReadyCode",
            "command": "dotnet",
            "type": "process",
            "args": [
                "run",
                "--project",
                "${workspaceFolder}/ReadyCode/ReadyCode.csproj",
                "-c",
                "Debug",
                "--no-build"
            ],
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "dependsOn": "Build ReadyCode"
        },
        {
            "label": "Publish MSIX (Store)",
            "command": "dotnet",
            "type": "process",
            "args": [
                "publish",
                "${workspaceFolder}/ReadyCode/ReadyCode.csproj",
                "-c", "Release",
                "-r", "win-x64",
                "--self-contained", "true",
                "-p:GenerateAppxPackageOnBuild=true",
                "-p:AppxPackageDir=${workspaceFolder}/Packages/",
                "-p:UapAppxPackageBuildMode=StoreUpload"
            ],
            "problemMatcher": "$msCompile"
        }
    ]
}
