<Application x:Class="ReadyCode.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:ReadyCode"
             StartupUri="Views/MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Themes/LightTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Global menu separator style — must live here (not Window.Resources) so that
                 shared ContextMenu resources can find it via the Application resource chain. -->
            <Style x:Key="{x:Static MenuItem.SeparatorStyleKey}" TargetType="Separator">
                <Setter Property="Height"              Value="1"/>
                <Setter Property="Margin"              Value="0,2"/>
                <Setter Property="HorizontalAlignment" Value="Stretch"/>
                <Setter Property="Background"          Value="{DynamicResource ThemeMenuItemBorder}"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Separator">
                            <Border Height="1" HorizontalAlignment="Stretch"
                                    Background="{TemplateBinding Background}"/>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
