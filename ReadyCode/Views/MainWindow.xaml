<Window x:Class="ReadyCode.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ReadyCode.Views"
        xmlns:models="clr-namespace:ReadyCode.Models"
        xmlns:avalonEdit="http://icsharpcode.net/sharpdevelop/avalonedit"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        mc:Ignorable="d"
        Title="{Binding ViewModel.Title}" Height="700" Width="1000"
        WindowStartupLocation="CenterScreen"
        PreviewKeyDown="Window_PreviewKeyDown"
        AllowDrop="True"
        PreviewDragEnter="Window_PreviewDragOver"
        PreviewDragOver="Window_PreviewDragOver"
        PreviewDrop="Window_PreviewDrop">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>

        <!-- Activity bar icon toggle button (left bar — active indicator on left edge) -->
        <Style x:Key="ActivityBarButton" TargetType="ToggleButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="#9D9D9D"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="border" Background="Transparent"
                                BorderThickness="2,0,0,0" BorderBrush="Transparent">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource ThemeActivityBarIndicator}"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Activity bar icon toggle button (right bar — active indicator on right edge) -->
        <Style x:Key="ActivityBarButtonRight" TargetType="ToggleButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="#9D9D9D"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="border" Background="Transparent"
                                BorderThickness="0,0,2,0" BorderBrush="Transparent">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource ThemeActivityBarIndicator}"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Context menu for editor tabs -->
        <ContextMenu x:Key="TabContextMenu" Opened="TabContextMenu_Opened">
            <MenuItem Header="Close"               InputGestureText="Ctrl+F4"  Click="TabContextClose_Click"/>
            <MenuItem Header="Close Others"                                     Click="TabContextCloseOthers_Click"/>
            <MenuItem Header="Close to the Right"                               Click="TabContextCloseToRight_Click"/>
            <MenuItem Header="Close Saved"         InputGestureText="Ctrl+K U" Click="TabContextCloseSaved_Click"/>
            <MenuItem Header="Close All"           InputGestureText="Ctrl+K W" Click="TabContextCloseAll_Click"/>
        </ContextMenu>

        <!-- Context menu for the text editor -->
        <ContextMenu x:Key="EditorContextMenu">
            <MenuItem Header="Transfer" InputGestureText="Ctrl+F5" Click="EditorContextTransfer_Click"/>
            <MenuItem Header="Run"      InputGestureText="F5"     Click="EditorContextRun_Click"/>
            <Separator/>
            <MenuItem Header="Go to Line Number" InputGestureText="F12" Click="EditorContextGoToLineNumber_Click"/>
            <Separator/>
            <MenuItem Header="Cut"   InputGestureText="Ctrl+X"   Click="EditCut_Click"/>
            <MenuItem Header="Copy"  InputGestureText="Ctrl+C"   Click="EditCopy_Click"/>
            <MenuItem Header="Paste" InputGestureText="Ctrl+V"   Click="EditPaste_Click"/>
            <Separator/>
            <MenuItem Header="Delete" InputGestureText="Delete"  Click="EditDelete_Click"/>
            <Separator/>
            <MenuItem Header="Minify Code"   InputGestureText="Ctrl+M"       Click="EditorContextMinify_Click"/>
            <MenuItem Header="Prettify Code" InputGestureText="Ctrl+Shift+M" Click="EditorContextPrettify_Click"/>
        </ContextMenu>

        <!-- Context menu for the root Explorer header -->
        <ContextMenu x:Key="RootFolderContextMenu" Opened="PasteContextMenu_Opened">
            <MenuItem Header="Paste" InputGestureText="Ctrl+V" Click="RootContextPaste_Click"/>
        </ContextMenu>

        <!-- Context menu for folder items in the Explorer tree -->
        <ContextMenu x:Key="FolderContextMenu" Opened="PasteContextMenu_Opened">
            <MenuItem Header="New File..."    Click="FolderContextNewFile_Click"/>
            <MenuItem Header="New Folder..."  Click="FolderContextNewFolder_Click"/>
            <Separator/>
            <MenuItem Header="Reveal in File Explorer" Click="FolderContextReveal_Click"/>
            <Separator/>
            <MenuItem Header="Cut"   InputGestureText="Ctrl+X" Click="FolderContextCut_Click"/>
            <MenuItem Header="Copy"  InputGestureText="Ctrl+C" Click="FolderContextCopy_Click"/>
            <MenuItem Header="Paste" InputGestureText="Ctrl+V" Click="FolderContextPaste_Click"/>
            <Separator/>
            <MenuItem Header="Rename..."  InputGestureText="F2"     Click="FolderContextRename_Click"/>
            <MenuItem Header="Delete"     InputGestureText="Delete" Click="FolderContextDelete_Click"/>
        </ContextMenu>

        <!-- Context menu for file items in the Explorer tree -->
        <ContextMenu x:Key="FileContextMenu" Opened="PasteContextMenu_Opened">
            <MenuItem Header="Reveal in File Explorer" Click="FileContextReveal_Click"/>
            <Separator/>
            <MenuItem Header="Cut"   InputGestureText="Ctrl+X" Click="FileContextCut_Click"/>
            <MenuItem Header="Copy"  InputGestureText="Ctrl+C" Click="FileContextCopy_Click"/>
            <MenuItem Header="Paste" InputGestureText="Ctrl+V" Click="FileContextPaste_Click"/>
            <Separator/>
            <MenuItem Header="Copy Path"          Click="FileContextCopyPath_Click"/>
            <MenuItem Header="Copy Relative Path" Click="FileContextCopyRelativePath_Click"/>
            <Separator/>
            <MenuItem Header="Rename..."  InputGestureText="F2"     Click="FileContextRename_Click"/>
            <MenuItem Header="Delete"     InputGestureText="Delete" Click="FileContextDelete_Click"/>
        </ContextMenu>

        <!-- Small icon button for Explorer panel header -->
        <Style x:Key="ExplorerHeaderButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="24"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeFolderExplorerIconFg}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="Transparent" CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource ThemeFolderExplorerBtnHover}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource ThemeFolderExplorerBtnPressed}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Close (×) button inside each editor tab -->
        <Style x:Key="TabCloseButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="16"/>
            <Setter Property="Height" Value="16"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="Arrow"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="Transparent" CornerRadius="2">
                            <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="9"
                                       Foreground="#888888"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource ThemeFolderExplorerBtnHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Button for inserting a PETSCII special character from the side panel -->
        <Style x:Key="SpecialCharButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="62"/>
            <Setter Property="Height" Value="60"/>
            <Setter Property="Margin" Value="3"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="{DynamicResource ThemeCardBg}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeFolderExplorerHeaderBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeSpecialCharIconFg}"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ThemeSpecialCharBtnHoverBg}"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource ThemeSpecialCharBtnHoverBorder}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ThemeSpecialCharBtnPressedBg}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ListBoxItem container for editor tabs -->
        <Style x:Key="TabItemContainerStyle" TargetType="ListBoxItem">
            <Setter Property="Background" Value="{DynamicResource ThemeTabInactiveBg}"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="ContextMenu" Value="{StaticResource TabContextMenu}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <!-- Outer border: right-side separator between tabs -->
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{DynamicResource ThemeTabItemBorder}" BorderThickness="0,0,1,0">
                            <!-- Inner border: top accent (blue when active) -->
                            <Border x:Name="TopAccent"
                                    BorderBrush="Transparent" BorderThickness="0,2,0,0">
                                <ContentPresenter/>
                            </Border>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="{DynamicResource ThemeTabActiveBg}"/>
                                <Setter TargetName="TopAccent" Property="BorderBrush" Value="#0066CC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ContextMenu popup container — full ControlTemplate removes WPF's hardcoded
             #F1F1F1 icon-column Rectangle that bleeds through as a white band. -->
        <Style TargetType="ContextMenu">
            <Setter Property="Background"      Value="{DynamicResource ThemeMenuItemBg}"/>
            <Setter Property="Foreground"      Value="{DynamicResource ThemeMenuItemFg}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource ThemeMenuItemBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ItemsPresenter SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Shared glyph style for standard menu icons (New/Save/Print/Cut/Copy/Paste/etc.) -->
        <Style x:Key="MenuItemIconText" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- Global MenuItem style: themes top-level bar items and all dropdown/submenu items -->
        <Style TargetType="MenuItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeMenuItemFg}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="Transparent" BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="20"/>   <!-- check mark -->
                                    <ColumnDefinition Width="*"/>    <!-- header text -->
                                    <ColumnDefinition Width="Auto"/> <!-- gesture text -->
                                    <ColumnDefinition Width="Auto"/> <!-- submenu arrow -->
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="CheckMark"
                                           Grid.Column="0"
                                           Text="✓"
                                           FontSize="11"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Visibility="Collapsed"
                                           Foreground="{TemplateBinding Foreground}"/>
                                <ContentPresenter Grid.Column="0"
                                                   ContentSource="Icon"
                                                   Width="16" Height="16"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                <AccessText x:Name="AccessText"
                                            Grid.Column="1"
                                            Text="{TemplateBinding Header}"
                                            Margin="0,4,8,4"
                                            VerticalAlignment="Center"/>
                                <TextBlock x:Name="GestureText"
                                           Grid.Column="2"
                                           Text="{TemplateBinding InputGestureText}"
                                           Foreground="{DynamicResource ThemeMenuItemFg}"
                                           Margin="16,4,8,4"
                                           VerticalAlignment="Center"
                                           Visibility="Collapsed"/>
                                <TextBlock x:Name="SubArrow"
                                           Grid.Column="3"
                                           Text="›"
                                           FontSize="14"
                                           Margin="4,0,6,0"
                                           VerticalAlignment="Center"
                                           Foreground="{TemplateBinding Foreground}"
                                           Visibility="Collapsed"/>
                                <Popup x:Name="PART_Popup"
                                       IsOpen="{TemplateBinding IsSubmenuOpen}"
                                       AllowsTransparency="True"
                                       Focusable="False"
                                       Placement="Bottom">
                                    <Border Background="{DynamicResource ThemeMenuItemBg}"
                                            BorderBrush="{DynamicResource ThemeMenuItemBorder}"
                                            BorderThickness="1"
                                            Padding="2">
                                        <ItemsPresenter/>
                                    </Border>
                                </Popup>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <!-- Top-level bar items: span AccessText over the check column so spacing is unchanged -->
                            <Trigger Property="Role" Value="TopLevelHeader">
                                <Setter TargetName="AccessText" Property="Grid.Column" Value="0"/>
                                <Setter TargetName="AccessText" Property="Grid.ColumnSpan" Value="2"/>
                                <Setter TargetName="AccessText" Property="Margin" Value="8,4,8,4"/>
                            </Trigger>
                            <Trigger Property="Role" Value="TopLevelItem">
                                <Setter TargetName="AccessText" Property="Grid.Column" Value="0"/>
                                <Setter TargetName="AccessText" Property="Grid.ColumnSpan" Value="2"/>
                                <Setter TargetName="AccessText" Property="Margin" Value="8,4,8,4"/>
                            </Trigger>
                            <!-- Submenu item: set popup bg as item bg, show gesture text -->
                            <Trigger Property="Role" Value="SubmenuItem">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource ThemeMenuItemBg}"/>
                                <Setter TargetName="GestureText" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <!-- Submenu header: same bg, popup opens to the right, show arrow -->
                            <Trigger Property="Role" Value="SubmenuHeader">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource ThemeMenuItemBg}"/>
                                <Setter TargetName="PART_Popup" Property="Placement" Value="Right"/>
                                <Setter TargetName="SubArrow" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <!-- Checked state: show the check mark glyph -->
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <!-- Hover/highlight state (overrides role bg) -->
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource ThemeMenuItemHoverBg}"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource ThemeMenuItemHoverBorder}"/>
                                <Setter Property="Foreground" Value="{DynamicResource ThemeMenuItemHoverFg}"/>
                                <Setter TargetName="GestureText" Property="Foreground" Value="{DynamicResource ThemeMenuItemHoverFg}"/>
                                <Setter TargetName="SubArrow" Property="Foreground" Value="{DynamicResource ThemeMenuItemHoverFg}"/>
                            </Trigger>
                            <!-- Disabled state -->
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{DynamicResource ThemeMenuItemDisabledFg}"/>
                                <Setter TargetName="GestureText" Property="Foreground" Value="{DynamicResource ThemeMenuItemDisabledFg}"/>
                            </Trigger>
                            <!-- No gesture text when InputGestureText is empty (overrides SubmenuItem trigger) -->
                            <DataTrigger Binding="{Binding InputGestureText, RelativeSource={RelativeSource TemplatedParent}}" Value="">
                                <Setter TargetName="GestureText" Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <!-- Input Bindings for Keyboard Shortcuts -->
    <Window.InputBindings>
        <!-- File Menu -->
        <KeyBinding Key="N" Modifiers="Ctrl" Command="{Binding FileNewCommand}"/>
        <KeyBinding Key="O" Modifiers="Ctrl" Command="{Binding FileOpenCommand}"/>
        <KeyBinding Key="S" Modifiers="Ctrl" Command="{Binding FileSaveCommand}"/>
        <KeyBinding Key="S" Modifiers="Ctrl+Shift" Command="{Binding FileSaveAsCommand}"/>
        <KeyBinding Key="P" Modifiers="Ctrl" Command="{Binding ViewModel.FilePrintCommand}"/>

        <!-- Edit Menu -->
        <KeyBinding Key="G" Modifiers="Ctrl" Command="{Binding EditGoToLineCommand}"/>
        <KeyBinding Key="F12" Command="{Binding GoToDefinitionCommand}"/>
        <KeyBinding Key="Z" Modifiers="Ctrl" Command="{Binding EditUndoCommand}"/>
        <KeyBinding Key="Y" Modifiers="Ctrl" Command="{Binding EditRedoCommand}"/>
        <KeyBinding Key="X" Modifiers="Ctrl" Command="{Binding EditCutCommand}"/>
        <KeyBinding Key="C" Modifiers="Ctrl" Command="{Binding EditCopyCommand}"/>
        <KeyBinding Key="V" Modifiers="Ctrl" Command="{Binding EditPasteCommand}"/>
        <KeyBinding Key="Delete" Command="{Binding EditDeleteCommand}"/>
        <KeyBinding Key="U" Modifiers="Ctrl+Shift" Command="{Binding EditMakeUppercaseCommand}"/>
        <KeyBinding Key="M" Modifiers="Ctrl"       Command="{Binding EditMinifyCommand}"/>
        <KeyBinding Key="M" Modifiers="Ctrl+Shift" Command="{Binding EditPrettifyCommand}"/>
        <KeyBinding Key="F" Modifiers="Ctrl" Command="{Binding EditFindCommand}"/>
        <KeyBinding Key="H" Modifiers="Ctrl" Command="{Binding EditReplaceCommand}"/>

        <!-- Tab management -->
        <KeyBinding Key="F4" Modifiers="Ctrl" Command="{Binding TabCloseCurrentCommand}"/>
        <KeyBinding Key="T"  Modifiers="Ctrl+Shift" Command="{Binding TabReopenClosedCommand}"/>

        <!-- View Menu -->
        <KeyBinding Key="B" Modifiers="Ctrl"       Command="{Binding ViewPrimarySideBarCommand}"/>
        <KeyBinding Key="B" Modifiers="Ctrl+Alt"   Command="{Binding ViewSecondarySideBarCommand}"/>
        <KeyBinding Key="E" Modifiers="Ctrl+Shift" Command="{Binding ViewExplorerCommand}"/>
        <KeyBinding Key="Z" Modifiers="Alt"        Command="{Binding ViewWordWrapCommand}"/>

        <!-- C64U Menu -->
        <KeyBinding Key="F5" Modifiers="Ctrl" Command="{Binding ViewModel.C64UTransferCommand}"/>
        <KeyBinding Key="F5" Command="{Binding ViewModel.C64URunCommand}"/>

        <!-- VICE Menu -->
        <KeyBinding Key="F5" Modifiers="Ctrl+Alt" Command="{Binding ViewModel.ViceTransferCommand}"/>
        <KeyBinding Key="F5" Modifiers="Alt" Command="{Binding ViewModel.ViceRunCommand}"/>

        <!-- Screen Control (Ctrl+1–8) -->
        <KeyBinding Key="D1" Modifiers="Ctrl" Command="{Binding InsertSpecialCharCommand}" CommandParameter="19"/>
        <KeyBinding Key="D2" Modifiers="Ctrl" Command="{Binding InsertSpecialCharCommand}" CommandParameter="147"/>
        <KeyBinding Key="D3" Modifiers="Ctrl" Command="{Binding InsertSpecialCharCommand}" CommandParameter="18"/>
        <KeyBinding Key="D4" Modifiers="Ctrl" Command="{Binding InsertSpecialCharCommand}" CommandParameter="146"/>
        <KeyBinding Key="D5" Modifiers="Ctrl" Command="{Binding InsertSpecialCharCommand}" CommandParameter="157"/>
        <KeyBinding Key="D6" Modifiers="Ctrl" Command="{Binding InsertSpecialCharCommand}" CommandParameter="29"/>
        <KeyBinding Key="D7" Modifiers="Ctrl" Command="{Binding InsertSpecialCharCommand}" CommandParameter="145"/>
        <KeyBinding Key="D8" Modifiers="Ctrl" Command="{Binding InsertSpecialCharCommand}" CommandParameter="17"/>

        <!-- Printing Colors CTRL+SHIFT+1–8: Black White Red Cyan Purple Green Blue Yellow -->
        <KeyBinding Key="D1" Modifiers="Ctrl+Shift" Command="{Binding InsertSpecialCharCommand}" CommandParameter="144"/>
        <KeyBinding Key="D2" Modifiers="Ctrl+Shift" Command="{Binding InsertSpecialCharCommand}" CommandParameter="5"/>
        <KeyBinding Key="D3" Modifiers="Ctrl+Shift" Command="{Binding InsertSpecialCharCommand}" CommandParameter="28"/>
        <KeyBinding Key="D4" Modifiers="Ctrl+Shift" Command="{Binding InsertSpecialCharCommand}" CommandParameter="159"/>
        <KeyBinding Key="D5" Modifiers="Ctrl+Shift" Command="{Binding InsertSpecialCharCommand}" CommandParameter="156"/>
        <KeyBinding Key="D6" Modifiers="Ctrl+Shift" Command="{Binding InsertSpecialCharCommand}" CommandParameter="30"/>
        <KeyBinding Key="D7" Modifiers="Ctrl+Shift" Command="{Binding InsertSpecialCharCommand}" CommandParameter="31"/>
        <KeyBinding Key="D8" Modifiers="Ctrl+Shift" Command="{Binding InsertSpecialCharCommand}" CommandParameter="158"/>

        <!-- Printing Colors CTRL+SHIFT+ALT+1–8: Orange Brown Lt.Red Gray1 Gray2 Lt.Green Lt.Blue Gray3 -->
        <KeyBinding Key="D1" Modifiers="Ctrl+Shift+Alt" Command="{Binding InsertSpecialCharCommand}" CommandParameter="129"/>
        <KeyBinding Key="D2" Modifiers="Ctrl+Shift+Alt" Command="{Binding InsertSpecialCharCommand}" CommandParameter="149"/>
        <KeyBinding Key="D3" Modifiers="Ctrl+Shift+Alt" Command="{Binding InsertSpecialCharCommand}" CommandParameter="150"/>
        <KeyBinding Key="D4" Modifiers="Ctrl+Shift+Alt" Command="{Binding InsertSpecialCharCommand}" CommandParameter="151"/>
        <KeyBinding Key="D5" Modifiers="Ctrl+Shift+Alt" Command="{Binding InsertSpecialCharCommand}" CommandParameter="152"/>
        <KeyBinding Key="D6" Modifiers="Ctrl+Shift+Alt" Command="{Binding InsertSpecialCharCommand}" CommandParameter="153"/>
        <KeyBinding Key="D7" Modifiers="Ctrl+Shift+Alt" Command="{Binding InsertSpecialCharCommand}" CommandParameter="154"/>
        <KeyBinding Key="D8" Modifiers="Ctrl+Shift+Alt" Command="{Binding InsertSpecialCharCommand}" CommandParameter="155"/>

        <!-- Function Keys SHIFT+F1-F8. Shift+F3 only reaches this binding when the Find bar is
             closed - Window_PreviewKeyDown claims it for Find Previous while the bar is open. -->
        <KeyBinding Key="F1" Modifiers="Shift" Command="{Binding InsertSpecialCharCommand}" CommandParameter="133"/>
        <KeyBinding Key="F2" Modifiers="Shift" Command="{Binding InsertSpecialCharCommand}" CommandParameter="137"/>
        <KeyBinding Key="F3" Modifiers="Shift" Command="{Binding InsertSpecialCharCommand}" CommandParameter="134"/>
        <KeyBinding Key="F4" Modifiers="Shift" Command="{Binding InsertSpecialCharCommand}" CommandParameter="138"/>
        <KeyBinding Key="F5" Modifiers="Shift" Command="{Binding InsertSpecialCharCommand}" CommandParameter="135"/>
        <KeyBinding Key="F6" Modifiers="Shift" Command="{Binding InsertSpecialCharCommand}" CommandParameter="139"/>
        <KeyBinding Key="F7" Modifiers="Shift" Command="{Binding InsertSpecialCharCommand}" CommandParameter="136"/>
        <KeyBinding Key="F8" Modifiers="Shift" Command="{Binding InsertSpecialCharCommand}" CommandParameter="140"/>
    </Window.InputBindings>

    <DockPanel>
        <!-- Menu Bar -->
        <Menu DockPanel.Dock="Top" Background="{DynamicResource ThemeMenuBg}" Foreground="{DynamicResource ThemeMenuFg}" Height="25">

            <MenuItem Header="_File">
                <MenuItem Header="_New"             Command="{Binding FileNewCommand}"          InputGestureText="Ctrl+N">
                    <MenuItem.Icon><TextBlock Text="&#xE7C3;" Style="{StaticResource MenuItemIconText}"/></MenuItem.Icon>
                </MenuItem>
                <Separator/>
                <MenuItem Header="_Open File..."    Command="{Binding FileOpenCommand}"         InputGestureText="Ctrl+O">
                    <MenuItem.Icon><TextBlock Text="&#xE8E5;" Style="{StaticResource MenuItemIconText}"/></MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="Open _Folder..."  Command="{Binding FileOpenFolderCommand}" InputGestureText="Ctrl+K Ctrl+O"/>
                <MenuItem Header="Open _Recent" x:Name="RecentFilesMenuItem">
                    <MenuItem Header="(none)" IsEnabled="False"/>
                </MenuItem>
                <MenuItem Header="Reopen Closed _Tab" Command="{Binding TabReopenClosedCommand}" InputGestureText="Ctrl+Shift+T"/>
                <Separator/>
                <MenuItem Header="_Close Editor" Command="{Binding TabCloseCurrentCommand}" InputGestureText="Ctrl+F4"/>
                <MenuItem Header="Close Fo_lder" Command="{Binding FileCloseFolderCommand}" InputGestureText="Ctrl+K F"/>
                <Separator/>
                <MenuItem Header="_Save"            Command="{Binding FileSaveCommand}"         InputGestureText="Ctrl+S">
                    <MenuItem.Icon><TextBlock Text="&#xE74E;" Style="{StaticResource MenuItemIconText}"/></MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="Save _As..."      Command="{Binding FileSaveAsCommand}"       InputGestureText="Ctrl+Shift+S">
                    <MenuItem.Icon><TextBlock Text="&#xE792;" Style="{StaticResource MenuItemIconText}"/></MenuItem.Icon>
                </MenuItem>
                <Separator/>
                <MenuItem Header="_Export..."  Command="{Binding FileExportCommand}"/>
                <MenuItem Header="_Import..."  Command="{Binding FileImportCommand}"/>
                <Separator/>
                <MenuItem Header="Pa_ge Setup..." Command="{Binding ViewModel.FilePageSetupCommand}"/>
                <MenuItem Header="Print Pre_view..." Command="{Binding ViewModel.FilePrintPreviewCommand}"/>
                <MenuItem Header="_Print..."      Command="{Binding ViewModel.FilePrintCommand}"     InputGestureText="Ctrl+P">
                    <MenuItem.Icon><TextBlock Text="&#xE749;" Style="{StaticResource MenuItemIconText}"/></MenuItem.Icon>
                </MenuItem>
                <Separator/>
                <MenuItem Header="E_xit" Click="FileExit_Click"/>
            </MenuItem>

            <MenuItem Header="_Edit">
                <MenuItem Header="_Undo"  Command="{Binding EditUndoCommand}"  InputGestureText="Ctrl+Z">
                    <MenuItem.Icon><TextBlock Text="&#xE7A7;" Style="{StaticResource MenuItemIconText}"/></MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="_Redo"  Command="{Binding EditRedoCommand}"  InputGestureText="Ctrl+Y">
                    <MenuItem.Icon><TextBlock Text="&#xE7A6;" Style="{StaticResource MenuItemIconText}"/></MenuItem.Icon>
                </MenuItem>
                <Separator/>
                <MenuItem Header="_Go to Line..." Command="{Binding EditGoToLineCommand}" InputGestureText="Ctrl+G"/>
                <Separator/>
                <MenuItem Header="Cu_t"   Command="{Binding EditCutCommand}"   InputGestureText="Ctrl+X">
                    <MenuItem.Icon><TextBlock Text="&#xE8C6;" Style="{StaticResource MenuItemIconText}"/></MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="_Copy"  Command="{Binding EditCopyCommand}"  InputGestureText="Ctrl+C">
                    <MenuItem.Icon><TextBlock Text="&#xE8C8;" Style="{StaticResource MenuItemIconText}"/></MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="_Paste" Command="{Binding EditPasteCommand}" InputGestureText="Ctrl+V">
                    <MenuItem.Icon><TextBlock Text="&#xE77F;" Style="{StaticResource MenuItemIconText}"/></MenuItem.Icon>
                </MenuItem>
                <Separator/>
                <MenuItem Header="_Delete" Command="{Binding EditDeleteCommand}" InputGestureText="Delete">
                    <MenuItem.Icon><TextBlock Text="&#xE74D;" Style="{StaticResource MenuItemIconText}"/></MenuItem.Icon>
                </MenuItem>
                <Separator/>
                <MenuItem Header="Comment _Selection"   Command="{Binding EditCommentCommand}"   InputGestureText="Ctrl+K Ctrl+C"/>
                <MenuItem Header="U_ncomment Selection" Command="{Binding EditUncommentCommand}" InputGestureText="Ctrl+K Ctrl+U"/>
                <Separator/>
                <MenuItem Header="M_ake Uppercase" Command="{Binding EditMakeUppercaseCommand}" InputGestureText="Ctrl+Shift+U"/>
                <MenuItem Header="Make _Lowercase" Command="{Binding EditMakeLowercaseCommand}"/>
                <Separator/>
                <MenuItem Header="Minif_y Code"   Command="{Binding EditMinifyCommand}"   InputGestureText="Ctrl+M"/>
                <MenuItem Header="Prett_ify Code" Command="{Binding EditPrettifyCommand}" InputGestureText="Ctrl+Shift+M"/>
                <Separator/>
                <MenuItem Header="_Find"    Command="{Binding EditFindCommand}"    InputGestureText="Ctrl+F">
                    <MenuItem.Icon><TextBlock Text="&#xE721;" Style="{StaticResource MenuItemIconText}"/></MenuItem.Icon>
                </MenuItem>
                <Separator/>
                <MenuItem Header="R_eplace" Command="{Binding EditReplaceCommand}" InputGestureText="Ctrl+H"/>
            </MenuItem>

            <MenuItem Header="_View">
                <MenuItem Header="_Column Guide"
                          IsCheckable="True"
                          IsChecked="{Binding ViewModel.ShowColumnGuide, Mode=TwoWay}"/>
                <Separator/>
                <MenuItem Header="_Primary Side Bar"
                          IsCheckable="True"
                          IsChecked="{Binding ViewModel.IsLeftPanelOpen}"
                          Command="{Binding ViewPrimarySideBarCommand}"
                          InputGestureText="Ctrl+B"/>
                <MenuItem Header="_Secondary Side Bar"
                          IsCheckable="True"
                          IsChecked="{Binding ViewModel.IsRightPanelOpen}"
                          Command="{Binding ViewSecondarySideBarCommand}"
                          InputGestureText="Ctrl+Alt+B"/>
                <Separator/>
                <MenuItem Header="_Explorer"
                          Command="{Binding ViewExplorerCommand}"
                          InputGestureText="Ctrl+Shift+E"/>
                <Separator/>
                <MenuItem Header="_Word Wrap"
                          IsCheckable="True"
                          IsChecked="{Binding ViewModel.WordWrap, Mode=TwoWay}"
                          InputGestureText="Alt+Z"/>
                <Separator/>
                <MenuItem Header="Code S_tatistics"
                          Command="{Binding ViewCodeStatisticsCommand}"/>
            </MenuItem>

            <MenuItem Header="C64_U" Visibility="{Binding ViewModel.ShowC64UMenu, Converter={StaticResource BoolToVisibility}}">
                <MenuItem Header="_Transfer" Command="{Binding ViewModel.C64UTransferCommand}" InputGestureText="Ctrl+F5"/>
                <MenuItem Header="_Run"      Command="{Binding ViewModel.C64URunCommand}" InputGestureText="F5">
                    <MenuItem.Icon><TextBlock Text="&#xE768;" Style="{StaticResource MenuItemIconText}"/></MenuItem.Icon>
                </MenuItem>
                <Separator/>
                <MenuItem Header="R_eset"     Command="{Binding ViewModel.C64UResetCommand}"/>
                <MenuItem Header="Re_boot"    Command="{Binding ViewModel.C64URebootCommand}"/>
                <MenuItem Header="_Pause"     Command="{Binding ViewModel.C64UPauseCommand}"/>
                <MenuItem Header="Res_ume"    Command="{Binding ViewModel.C64UResumeCommand}"/>
                <MenuItem Header="Power _Off" Command="{Binding ViewModel.C64UPowerOffCommand}"/>
                <Separator/>
                <MenuItem Header="_About My C64U" Command="{Binding ViewModel.C64USystemInfoCommand}"/>
            </MenuItem>

            <MenuItem Header="VI_CE" Visibility="{Binding ViewModel.ShowViceMenu, Converter={StaticResource BoolToVisibility}}">
                <MenuItem Header="_Transfer" Command="{Binding ViewModel.ViceTransferCommand}" InputGestureText="Ctrl+Alt+F5"/>
                <MenuItem Header="_Run"      Command="{Binding ViewModel.ViceRunCommand}" InputGestureText="Alt+F5">
                    <MenuItem.Icon><TextBlock Text="&#xE768;" Style="{StaticResource MenuItemIconText}"/></MenuItem.Icon>
                </MenuItem>
                <Separator/>
                <MenuItem Header="R_eset"     Command="{Binding ViewModel.ViceResetCommand}"/>
                <MenuItem Header="Re_boot"    Command="{Binding ViewModel.ViceRebootCommand}"/>
                <MenuItem Header="_Pause"     Command="{Binding ViewModel.VicePauseCommand}"/>
                <MenuItem Header="Res_ume"    Command="{Binding ViewModel.ViceResumeCommand}"/>
                <MenuItem Header="Power _Off" Command="{Binding ViewModel.VicePowerOffCommand}"/>
                <Separator/>
                <MenuItem Header="_About VICE" Command="{Binding ViewModel.ViceSystemInfoCommand}"/>
            </MenuItem>

            <MenuItem Header="_Preferences">
                <MenuItem Header="Show Status _Bar"
                          IsCheckable="True"
                          IsChecked="{Binding ViewModel.ShowStatusBar, Mode=TwoWay}"/>
                <Separator/>
                <MenuItem Header="_Settings..." Command="{Binding PreferencesSettingsCommand}"/>
            </MenuItem>

            <MenuItem Header="_Help">
                <MenuItem Header="Visit READYCode on _GitHub" Command="{Binding ViewModel.HelpGitHubCommand}"/>
                <Separator/>
                <MenuItem Header="_About READYCode" Command="{Binding ViewModel.HelpAboutCommand}"/>
            </MenuItem>

        </Menu>

        <!-- Status Bar -->
        <StatusBar DockPanel.Dock="Bottom" Background="{DynamicResource ThemeStatusBarBg}" Foreground="{DynamicResource ThemeStatusBarFg}" Height="24"
                   Visibility="{Binding ViewModel.ShowStatusBar, Converter={StaticResource BoolToVisibility}}">
            <StatusBarItem Margin="5,0,0,0">
                <TextBlock Text="{Binding ViewModel.FileStatusText}" FontSize="11"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem Margin="5,0,0,0">
                <TextBlock Text="{Binding ViewModel.LineCountText}" FontSize="11"/>
            </StatusBarItem>
            <Separator/>

            <StatusBarItem HorizontalAlignment="Right" Margin="0,0,10,0">
                <TextBlock Text="{Binding ViewModel.ScreenPositionText}" FontSize="11"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem HorizontalAlignment="Stretch" HorizontalContentAlignment="Left">
                <StatusBarItem.Style>
                    <Style TargetType="StatusBarItem">
                        <Setter Property="Background" Value="Transparent"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ViewModel.StatusType}" Value="Warning">
                                <Setter Property="Background" Value="{DynamicResource ThemeStatusWarningBg}"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding ViewModel.StatusType}" Value="Error">
                                <Setter Property="Background" Value="{DynamicResource ThemeStatusErrorBg}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StatusBarItem.Style>
                <TextBlock Text="{Binding ViewModel.StatusMessage}" FontSize="11">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{DynamicResource ThemeStatusBarFg}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ViewModel.StatusType}" Value="Warning">
                                    <Setter Property="Foreground" Value="{DynamicResource ThemeStatusWarningFg}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding ViewModel.StatusType}" Value="Error">
                                    <Setter Property="Foreground" Value="{DynamicResource ThemeStatusErrorFg}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StatusBarItem>
        </StatusBar>

        <!-- Main content: activity bars + side panels + editor -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="40"/><!-- Left activity bar -->
                <ColumnDefinition x:Name="LeftPanelCol" Width="0" MinWidth="0"/><!-- Left panel -->
                <ColumnDefinition x:Name="LeftSplitterCol" Width="0" MinWidth="0"/><!-- Left splitter -->
                <ColumnDefinition Width="*" MinWidth="100"/><!-- Editor -->
                <ColumnDefinition x:Name="RightSplitterCol" Width="0" MinWidth="0"/><!-- Right splitter -->
                <ColumnDefinition x:Name="RightPanelCol" Width="0" MinWidth="0"/><!-- Right panel -->
                <ColumnDefinition Width="40"/><!-- Right activity bar -->
            </Grid.ColumnDefinitions>

            <!-- Left activity bar -->
            <Border Grid.Column="0" Background="#3C3C3C"
                    BorderBrush="#2D2D2D" BorderThickness="0,0,1,0">
                <StackPanel VerticalAlignment="Top">
                    <ToggleButton x:Name="ExplorerToggle"
                                  Style="{StaticResource ActivityBarButton}"
                                  ToolTip="Explorer"
                                  Click="ExplorerToggle_Click">
                        <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                   Foreground="{Binding RelativeSource={RelativeSource AncestorType=ToggleButton}, Path=Foreground}"/>
                    </ToggleButton>
                </StackPanel>
            </Border>

            <!-- Left panel: Explorer (file tree) -->
            <Grid Grid.Column="1">
                <DockPanel Background="{DynamicResource ThemeFolderExplorerBg}">
                    <Border x:Name="ExplorerHeaderBorder"
                            DockPanel.Dock="Top"
                            Background="{DynamicResource ThemeFolderExplorerHeaderBg}"
                            BorderBrush="{DynamicResource ThemeFolderExplorerHeaderBorder}" BorderThickness="0,0,0,1"
                            Height="32"
                            AllowDrop="True"
                            ContextMenu="{StaticResource RootFolderContextMenu}"
                            DragOver="RootHeader_DragOver"
                            DragLeave="RootHeader_DragLeave"
                            Drop="RootHeader_Drop">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="{Binding ViewModel.ExplorerTitle}"
                                       FontSize="11" FontWeight="Bold" Foreground="{DynamicResource ThemeFileFg}"
                                       VerticalAlignment="Center" Margin="10,0,0,0"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal"
                                        VerticalAlignment="Center" Margin="0,0,4,0">
                                <Button Style="{StaticResource ExplorerHeaderButton}"
                                        ToolTip="New File"
                                        Click="ExplorerNewFile_Click">
                                    <TextBlock Text="&#xE7C3;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                               Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"/>
                                </Button>
                                <Button Style="{StaticResource ExplorerHeaderButton}"
                                        ToolTip="New Folder"
                                        Click="ExplorerNewFolder_Click">
                                    <TextBlock Text="&#xED25;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                               Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"/>
                                </Button>
                                <Button Style="{StaticResource ExplorerHeaderButton}"
                                        ToolTip="Refresh Explorer"
                                        Click="ExplorerRefresh_Click">
                                    <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                               Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"/>
                                </Button>
                                <Button Style="{StaticResource ExplorerHeaderButton}"
                                        ToolTip="Collapse Folders in Explorer"
                                        Click="ExplorerCollapse_Click">
                                    <TextBlock Text="&#xE8D8;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                               Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"/>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <TreeView x:Name="FileTree"
                              Background="{DynamicResource ThemeFolderExplorerBg}"
                              BorderThickness="0"
                              AllowDrop="True"
                              ItemsSource="{Binding ViewModel.FolderItems}"
                              MouseDoubleClick="FileTree_MouseDoubleClick"
                              PreviewMouseLeftButtonDown="FileTree_PreviewMouseLeftButtonDown"
                              PreviewKeyDown="FileTree_PreviewKeyDown">
                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                <Grid>
                                    <TextBlock x:Name="itemText"
                                               Text="{Binding Name}"
                                               FontSize="12" Foreground="{DynamicResource ThemeFileFg}"
                                               Margin="0,1" VerticalAlignment="Center"/>
                                    <TextBox x:Name="RenameBox"
                                             Visibility="Collapsed"
                                             Text="{Binding Name, Mode=OneTime}"
                                             FontSize="12"
                                             Foreground="{DynamicResource ThemeFileFg}"
                                             Background="{DynamicResource ThemeSettingsInputBg}"
                                             BorderBrush="{DynamicResource ThemeSettingsAccent}"
                                             BorderThickness="1"
                                             CaretBrush="{DynamicResource ThemeFileFg}"
                                             Padding="2,0" Margin="-3,0"
                                             VerticalContentAlignment="Center"
                                             KeyDown="RenameBox_KeyDown"
                                             LostFocus="RenameBox_LostFocus"/>
                                </Grid>
                                <HierarchicalDataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding IsFolder}" Value="True">
                                        <Setter TargetName="itemText"  Property="FontWeight" Value="SemiBold"/>
                                        <Setter TargetName="RenameBox" Property="FontWeight" Value="SemiBold"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsRenaming}" Value="True">
                                        <Setter TargetName="itemText"  Property="Visibility" Value="Collapsed"/>
                                        <Setter TargetName="RenameBox" Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </HierarchicalDataTemplate.Triggers>
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                        <TreeView.ItemContainerStyle>
                            <Style TargetType="TreeViewItem">
                                <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                                <EventSetter Event="PreviewMouseMove" Handler="FileTreeItem_PreviewMouseMove"/>
                                <EventSetter Event="DragOver"         Handler="FileTreeItem_DragOver"/>
                                <EventSetter Event="DragLeave"        Handler="FileTreeItem_DragLeave"/>
                                <EventSetter Event="Drop"             Handler="FileTreeItem_Drop"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="TreeViewItem">
                                            <StackPanel>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="16"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <!-- Full-row background spans both columns -->
                                                    <Border x:Name="RowBg"
                                                            Grid.ColumnSpan="2"
                                                            Background="Transparent"
                                                            SnapsToDevicePixels="True"/>
                                                    <!-- Expand/collapse toggle -->
                                                    <ToggleButton x:Name="Expander"
                                                                  Grid.Column="0"
                                                                  Focusable="False"
                                                                  IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                                                  ClickMode="Press">
                                                        <ToggleButton.Style>
                                                            <Style TargetType="ToggleButton">
                                                                <Setter Property="Background" Value="Transparent"/>
                                                                <Setter Property="BorderThickness" Value="0"/>
                                                                <Setter Property="Template">
                                                                    <Setter.Value>
                                                                        <ControlTemplate TargetType="ToggleButton">
                                                                            <Border Background="Transparent" Width="16" Height="16">
                                                                                <Path x:Name="Arrow"
                                                                                      Data="M 5 3 L 11 8 L 5 13 Z"
                                                                                      Fill="#888888"
                                                                                      HorizontalAlignment="Center"
                                                                                      VerticalAlignment="Center"/>
                                                                            </Border>
                                                                            <ControlTemplate.Triggers>
                                                                                <Trigger Property="IsChecked" Value="True">
                                                                                    <Setter TargetName="Arrow" Property="Data" Value="M 3 5 L 13 5 L 8 11 Z"/>
                                                                                </Trigger>
                                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                                    <Setter TargetName="Arrow" Property="Fill" Value="#555555"/>
                                                                                </Trigger>
                                                                            </ControlTemplate.Triggers>
                                                                        </ControlTemplate>
                                                                    </Setter.Value>
                                                                </Setter>
                                                            </Style>
                                                        </ToggleButton.Style>
                                                    </ToggleButton>
                                                    <!-- Item content (file/folder name) -->
                                                    <ContentPresenter x:Name="PART_Header"
                                                                      Grid.Column="1"
                                                                      ContentSource="Header"
                                                                      HorizontalAlignment="Left"
                                                                      VerticalAlignment="Center"
                                                                      Margin="2,2"/>
                                                </Grid>
                                                <!-- Children shown when expanded -->
                                                <ItemsPresenter x:Name="ItemsHost"
                                                                Visibility="Collapsed"
                                                                Margin="16,0,0,0"/>
                                            </StackPanel>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsExpanded" Value="True">
                                                    <Setter TargetName="ItemsHost" Property="Visibility" Value="Visible"/>
                                                </Trigger>
                                                <Trigger Property="HasItems" Value="False">
                                                    <Setter TargetName="Expander" Property="Visibility" Value="Hidden"/>
                                                </Trigger>
                                                <!-- Hover -->
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="RowBg" Property="Background" Value="{DynamicResource ThemeFolderExplorerHoverBg}"/>
                                                </Trigger>
                                                <!-- Active selection (overrides hover) -->
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="RowBg" Property="Background" Value="{DynamicResource ThemeFileSelectedBg}"/>
                                                </Trigger>
                                                <!-- Inactive selection -->
                                                <MultiTrigger>
                                                    <MultiTrigger.Conditions>
                                                        <Condition Property="IsSelected" Value="True"/>
                                                        <Condition Property="IsSelectionActive" Value="False"/>
                                                    </MultiTrigger.Conditions>
                                                    <Setter TargetName="RowBg" Property="Background" Value="{DynamicResource ThemeFileInactiveSelectedBg}"/>
                                                </MultiTrigger>
                                                <!-- Drop target (overrides all) -->
                                                <DataTrigger Binding="{Binding IsDropTarget}" Value="True">
                                                    <Setter TargetName="RowBg" Property="Background" Value="#FFF3CD"/>
                                                    <Setter TargetName="RowBg" Property="BorderBrush" Value="#FFC107"/>
                                                    <Setter TargetName="RowBg" Property="BorderThickness" Value="1"/>
                                                </DataTrigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsFolder}" Value="True">
                                        <Setter Property="ContextMenu" Value="{StaticResource FolderContextMenu}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsFolder}" Value="False">
                                        <Setter Property="ContextMenu" Value="{StaticResource FileContextMenu}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TreeView.ItemContainerStyle>
                    </TreeView>
                </DockPanel>
            </Grid>

            <!-- Left GridSplitter -->
            <GridSplitter Grid.Column="2"
                          HorizontalAlignment="Stretch"
                          Background="{DynamicResource ThemeSplitter}"
                          ResizeBehavior="PreviousAndNext"
                          ShowsPreview="False"/>

            <!-- Main editor area: tab bar + editor -->
            <Grid Grid.Column="3">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Tab bar -->
                <Border Grid.Row="0" Background="{DynamicResource ThemeTabBarBg}"
                        BorderBrush="{DynamicResource ThemeTabBorder}" BorderThickness="0,0,0,1">
                    <ListBox x:Name="TabBar"
                             ItemsSource="{Binding ViewModel.OpenTabs}"
                             Background="Transparent"
                             BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Auto"
                             ScrollViewer.VerticalScrollBarVisibility="Disabled"
                             SelectionChanged="TabBar_SelectionChanged"
                             ItemContainerStyle="{StaticResource TabItemContainerStyle}">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:EditorTab}">
                                <Border Height="33" MinWidth="80" MaxWidth="220">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="20"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock x:Name="TabFileName"
                                                   Grid.Column="0"
                                                   Text="{Binding FileName}"
                                                   VerticalAlignment="Center"
                                                   Padding="10,0,4,0"
                                                   FontSize="12"
                                                   Foreground="{DynamicResource ThemeTabInactiveFg}"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <Grid Grid.Column="1" Width="16" Height="16"
                                              VerticalAlignment="Center" HorizontalAlignment="Center">
                                            <!-- Modified dot (shown when modified and tab not hovered) -->
                                            <Ellipse x:Name="ModifiedDot"
                                                     Width="8" Height="8"
                                                     Fill="#6B69D6"
                                                     Visibility="Collapsed"/>
                                            <!-- Close button (shown when tab is hovered) -->
                                            <Button x:Name="CloseBtn"
                                                    Style="{StaticResource TabCloseButtonStyle}"
                                                    Click="TabClose_Click"
                                                    Visibility="Hidden"/>
                                        </Grid>
                                    </Grid>
                                </Border>
                                <DataTemplate.Triggers>
                                    <!-- Hovering: always show X -->
                                    <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                        <Setter TargetName="CloseBtn" Property="Visibility" Value="Visible"/>
                                        <Setter TargetName="ModifiedDot" Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                    <!-- Not hovering + modified: show dot -->
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding IsModified}" Value="True"/>
                                            <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="False"/>
                                        </MultiDataTrigger.Conditions>
                                        <MultiDataTrigger.Setters>
                                            <Setter TargetName="ModifiedDot" Property="Visibility" Value="Visible"/>
                                        </MultiDataTrigger.Setters>
                                    </MultiDataTrigger>
                                    <!-- Active tab: brighter foreground -->
                                    <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                        <Setter TargetName="TabFileName" Property="Foreground" Value="{DynamicResource ThemeTabActiveFg}"/>
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>

                <!-- Editor + Find Bar overlay -->
                <Grid Grid.Row="1" Background="{DynamicResource ThemeEditorBg}">
                    <!-- Shown only while no tabs are open; ActivateTab toggles this and the Editor's
                         visibility together so an open tab always covers it. -->
                    <Image x:Name="EmptyStateImage"
                           Source="/ReadyCode;component/Assets/READYCode-01-tra-1024x1024.png"
                           Stretch="Uniform"
                           Width="320" Height="320"
                           Opacity="0.5"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Visibility="Visible"/>
                    <avalonEdit:TextEditor x:Name="Editor"
                             Margin="0"
                             Padding="10"
                             FontFamily="../Assets/Fonts/#Pet Me 64"
                             FontSize="16"
                             Foreground="#000000"
                             Background="{DynamicResource ThemeEditorBg}"
                             WordWrap="False"
                             ShowLineNumbers="False"
                             HorizontalScrollBarVisibility="Auto"
                             VerticalScrollBarVisibility="Auto"
                             ContextMenu="{StaticResource EditorContextMenu}"
                             TextChanged="Editor_TextChanged"
                             PreviewKeyDown="Editor_PreviewKeyDown"
                             PreviewTextInput="Editor_PreviewTextInput"
                             MouseHover="Editor_MouseHover"
                             MouseHoverStopped="Editor_MouseHoverStopped"
                             PreviewMouseRightButtonDown="Editor_PreviewMouseRightButtonDown"
                             Visibility="Collapsed"/>
                    <local:FindBarControl x:Name="FindBar"
                                         HorizontalAlignment="Right"
                                         VerticalAlignment="Top"
                                         Margin="0,0,20,0"
                                         Panel.ZIndex="10"
                                         Width="440"/>
                </Grid>
            </Grid>

            <!-- Right GridSplitter -->
            <GridSplitter Grid.Column="4"
                          HorizontalAlignment="Stretch"
                          Background="{DynamicResource ThemeSplitter}"
                          ResizeBehavior="PreviousAndNext"
                          ShowsPreview="False"/>

            <!-- Right panel: Special Characters, PETSCII Reference, BASIC Keywords -->
            <Grid Grid.Column="5">
                <!-- PETSCII Reference panel -->
                <DockPanel x:Name="PetsciiPanel" Background="{DynamicResource ThemeFolderExplorerBg}" Visibility="Collapsed">
                    <Border DockPanel.Dock="Top"
                            Background="{DynamicResource ThemeFolderExplorerHeaderBg}"
                            BorderBrush="{DynamicResource ThemeFolderExplorerHeaderBorder}" BorderThickness="0,0,0,1"
                            Height="32">
                        <TextBlock Text="PETSCII REFERENCE"
                                   FontSize="11" FontWeight="Bold" Foreground="{DynamicResource ThemeFileFg}"
                                   VerticalAlignment="Center" Margin="10,0,0,0"/>
                    </Border>
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel x:Name="PetsciiTablePanel" Margin="8,8,0,0"/>
                    </ScrollViewer>
                </DockPanel>

                <!-- Quick Keys panel -->
                <DockPanel x:Name="SpecialCharsPanel" Background="{DynamicResource ThemeFolderExplorerBg}">
                    <Border DockPanel.Dock="Top"
                            Background="{DynamicResource ThemeFolderExplorerHeaderBg}"
                            BorderBrush="{DynamicResource ThemeFolderExplorerHeaderBorder}" BorderThickness="0,0,0,1"
                            Height="32">
                        <TextBlock Text="QUICK KEYS"
                                   FontSize="11" FontWeight="Bold" Foreground="{DynamicResource ThemeFileFg}"
                                   VerticalAlignment="Center" Margin="10,0,0,0"/>
                    </Border>
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel>
                            <!-- Screen Control section -->
                            <TextBlock Text="SCREEN CONTROL"
                                       FontSize="10" FontWeight="Bold"
                                       Foreground="{DynamicResource ThemePanelHeaderFg}"
                                       Background="{DynamicResource ThemePanelHeaderBg}"
                                       MinHeight="22"
                                       VerticalAlignment="Center"
                                       Padding="8,4,0,4"
                                       Margin="8,8"/>
                            <TextBlock Text="CTRL+1–8"
