                                <!-- Light Green — PETSCII 153 → screen code 0xD9 → PUA U+E0D9 -->
                                <Button Style="{StaticResource SpecialCharButtonStyle}"
                                        Tag="153" Click="SpecialChar_Click"
                                        ToolTip="Light Green: Ctrl+Shift+Alt+6; CHR$(153); POKE(13)">
                                    <Grid Width="58" Height="54">
                                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock Text="&#xE0D9;" FontFamily="../Assets/Fonts/#Pet Me 64" FontSize="20"
                                                       Foreground="#9FEF93"
                                                       HorizontalAlignment="Center"/>
                                            <TextBlock Text="LT. GREEN" FontFamily="Segoe UI" FontSize="8"
                                                       Foreground="{DynamicResource ThemeSpecialCharLabelFg}" HorizontalAlignment="Center"
                                                       Margin="0,2,0,0"/>
                                        </StackPanel>
                                        <TextBlock Text="6" FontFamily="Segoe UI" FontSize="8" FontWeight="SemiBold"
