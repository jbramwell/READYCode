                                                   HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                                   Margin="0,0,3,2"/>
                                    </Grid>
                                </Button>
                                <!-- Light Blue — PETSCII 154 → screen code 0xDA → PUA U+E0DA -->
                                <Button Style="{StaticResource SpecialCharButtonStyle}"
                                        Tag="154" Click="SpecialChar_Click"
                                        ToolTip="Light Blue: Ctrl+Shift+Alt+7; CHR$(154); POKE(14)">
                                    <Grid Width="58" Height="54">
                                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock Text="&#xE0DA;" FontFamily="../Assets/Fonts/#Pet Me 64" FontSize="20"
                                                       Foreground="#6D6AEF"
                                                       HorizontalAlignment="Center"/>
                                            <TextBlock Text="LT. BLUE" FontFamily="Segoe UI" FontSize="9"
                                                       Foreground="{DynamicResource ThemeSpecialCharLabelFg}" HorizontalAlignment="Center"
                                                       Margin="0,2,0,0"/>
                                        </StackPanel>
                                        <TextBlock Text="7" FontFamily="Segoe UI" FontSize="8" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource ThemeSpecialCharShortcutFg}"
                                                   HorizontalAlignment="Left" VerticalAlignment="Bottom"
                                                   Margin="3,0,0,2"/>
                                        <TextBlock Text="14" FontFamily="Segoe UI" FontSize="8" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource ThemeSpecialCharShortcutFg}"
                                                   HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                                   Margin="0,0,3,2"/>
                                    </Grid>
                                </Button>
                                <!-- Gray 3 — PETSCII 155 → screen code 0xDB → PUA U+E0DB -->
                                <Button Style="{StaticResource SpecialCharButtonStyle}"
                                        Tag="155" Click="SpecialChar_Click"
                                        ToolTip="Gray 3: Ctrl+Shift+Alt+8; CHR$(155); POKE(15)">
                                    <Grid Width="58" Height="54">
                                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock Text="&#xE0DB;" FontFamily="../Assets/Fonts/#Pet Me 64" FontSize="20"
                                                       Foreground="#B2B2B2"
                                                       HorizontalAlignment="Center"/>
                                            <TextBlock Text="GRAY 3" FontFamily="Segoe UI" FontSize="9"
                                                       Foreground="{DynamicResource ThemeSpecialCharLabelFg}" HorizontalAlignment="Center"
                                                       Margin="0,2,0,0"/>
                                        </StackPanel>
                                        <TextBlock Text="8" FontFamily="Segoe UI" FontSize="8" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource ThemeSpecialCharShortcutFg}"
                                                   HorizontalAlignment="Left" VerticalAlignment="Bottom"
                                                   Margin="3,0,0,2"/>
                                        <TextBlock Text="15" FontFamily="Segoe UI" FontSize="8" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource ThemeSpecialCharShortcutFg}"
                                                   HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                                   Margin="0,0,3,2"/>
                                    </Grid>
                                </Button>
                            </WrapPanel>

                            <!-- Function Keys section -->
                            <TextBlock Text="FUNCTION KEYS"
                                       FontSize="10" FontWeight="Bold"
                                       Foreground="{DynamicResource ThemePanelHeaderFg}"
                                       Background="{DynamicResource ThemePanelHeaderBg}"
                                       MinHeight="22"
                                       VerticalAlignment="Center"
                                       Padding="8,4,0,4"
                                       Margin="8,8"/>

                            <!-- SHIFT+F1-F8 (Shift+F3 does Find Previous instead while the Find bar is open) -->
                            <TextBlock Text="SHIFT+F1–F8"
                                       FontSize="9"
                                       Foreground="{DynamicResource ThemeSpecialCharShortcutFg}"
                                       Margin="8,0,8,4"/>
                            <WrapPanel Margin="6,0">
                                <!-- F1 — PETSCII 133 -->
                                <Button Style="{StaticResource SpecialCharButtonStyle}"
                                        Tag="133" Click="SpecialChar_Click"
                                        ToolTip="Function 1: Shift+F1; CHR$(133)">
                                    <Grid Width="58" Height="54">
                                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Border Background="{DynamicResource ThemePanelHeaderBg}" CornerRadius="2" Padding="6,2,6,2">
                                                <TextBlock Text="F1" FontFamily="Segoe UI" FontSize="14" FontWeight="Bold"
                                                           Foreground="{DynamicResource ThemePanelHeaderFg}" HorizontalAlignment="Center"/>
                                            </Border>
                                            <TextBlock Text="FUNC 1" FontFamily="Segoe UI" FontSize="9"
                                                       Foreground="{DynamicResource ThemeSpecialCharLabelFg}" HorizontalAlignment="Center"
                                                       Margin="0,2,0,0"/>
                                        </StackPanel>
                                        <TextBlock Text="F1" FontFamily="Segoe UI" FontSize="8" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource ThemeSpecialCharShortcutFg}"
                                                   HorizontalAlignment="Left" VerticalAlignment="Bottom"
                                                   Margin="3,0,0,2"/>
                                    </Grid>
                                </Button>
                                <!-- F2 — PETSCII 137 -->
                                <Button Style="{StaticResource SpecialCharButtonStyle}"
                                        Tag="137" Click="SpecialChar_Click"
                                        ToolTip="Function 2: Shift+F2; CHR$(137)">
