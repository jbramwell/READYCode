                                        </StackPanel>
                                        <TextBlock Text="F8" FontFamily="Segoe UI" FontSize="8" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource ThemeSpecialCharShortcutFg}"
                                                   HorizontalAlignment="Left" VerticalAlignment="Bottom"
                                                   Margin="3,0,0,2"/>
                                    </Grid>
                                </Button>
                            </WrapPanel>
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>

                <!-- BASIC Keywords panel -->
                <DockPanel x:Name="BasicKeywordsPanel" Background="{DynamicResource ThemeFolderExplorerBg}" Visibility="Collapsed">
                    <Border DockPanel.Dock="Top"
                            Background="{DynamicResource ThemeFolderExplorerHeaderBg}"
                            BorderBrush="{DynamicResource ThemeFolderExplorerHeaderBorder}" BorderThickness="0,0,0,1"
                            Height="32">
                        <TextBlock Text="BASIC KEYWORDS"
                                   FontSize="11" FontWeight="Bold" Foreground="{DynamicResource ThemeFileFg}"
                                   VerticalAlignment="Center" Margin="10,0,0,0"/>
                    </Border>
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel x:Name="BasicKeywordsListPanel" />
                    </ScrollViewer>
                </DockPanel>

                <!-- Music Notes panel -->
                <DockPanel x:Name="MusicNotesPanel" Background="{DynamicResource ThemeFolderExplorerBg}" Visibility="Collapsed">
                    <Border DockPanel.Dock="Top"
                            Background="{DynamicResource ThemeFolderExplorerHeaderBg}"
                            BorderBrush="{DynamicResource ThemeFolderExplorerHeaderBorder}" BorderThickness="0,0,0,1"
                            Height="32">
                        <TextBlock Text="MUSIC NOTES"
                                   FontSize="11" FontWeight="Bold" Foreground="{DynamicResource ThemeFileFg}"
                                   VerticalAlignment="Center" Margin="10,0,0,0"/>
                    </Border>
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Auto">
                        <Grid x:Name="MusicNotesGrid" Margin="8,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" MinWidth="32"/>
                                <ColumnDefinition Width="Auto" MinWidth="48"/>
                                <ColumnDefinition Width="Auto" MinWidth="50"/>
                                <ColumnDefinition Width="Auto" MinWidth="30"/>
                                <ColumnDefinition Width="Auto" MinWidth="36"/>
                                <ColumnDefinition Width="Auto" MinWidth="50"/>
                                <ColumnDefinition Width="Auto" MinWidth="30"/>
                                <ColumnDefinition Width="Auto" MinWidth="36"/>
                            </Grid.ColumnDefinitions>
                        </Grid>
                    </ScrollViewer>
                </DockPanel>
            </Grid>

            <!-- Right activity bar -->
            <Border Grid.Column="6" Background="#3C3C3C"
                    BorderBrush="#2D2D2D" BorderThickness="1,0,0,0">
                <StackPanel VerticalAlignment="Top">
                    <ToggleButton x:Name="SpecialCharsToggle"
                                  Style="{StaticResource ActivityBarButtonRight}"
                                  ToolTip="Quick Keys"
                                  Click="SpecialCharsToggle_Click">
                        <TextBlock Text="&#xE945;" FontSize="18" FontFamily="Segoe MDL2 Assets"
                                   Foreground="{Binding RelativeSource={RelativeSource AncestorType=ToggleButton}, Path=Foreground}"/>
                    </ToggleButton>
                    <ToggleButton x:Name="PetsciiToggle"
                                  Style="{StaticResource ActivityBarButtonRight}"
                                  ToolTip="PETSCII Reference"
                                  Click="PetsciiToggle_Click">
                        <TextBlock Text="&#x2663;" FontSize="24" FontWeight="Bold" FontFamily="Segoe UI Symbol"
                                   Foreground="{Binding RelativeSource={RelativeSource AncestorType=ToggleButton}, Path=Foreground}"/>
                    </ToggleButton>
                    <ToggleButton x:Name="BasicKeywordsToggle"
                                  Style="{StaticResource ActivityBarButtonRight}"
                                  ToolTip="BASIC Keywords"
                                  Click="BasicKeywordsToggle_Click">
                        <TextBlock Text="&#xE82D;" FontSize="18" FontFamily="Segoe MDL2 Assets"
                                   Margin="2,4,0,0"
                                   Foreground="{Binding RelativeSource={RelativeSource AncestorType=ToggleButton}, Path=Foreground}"/>
                    </ToggleButton>
                    <ToggleButton x:Name="MusicNotesToggle"
                                  Style="{StaticResource ActivityBarButtonRight}"
                                  ToolTip="Music Notes"
                                  Click="MusicNotesToggle_Click">
                        <TextBlock Text="&#x266B;" FontSize="20" FontFamily="Segoe UI Symbol"
                                   Foreground="{Binding RelativeSource={RelativeSource AncestorType=ToggleButton}, Path=Foreground}"/>
                    </ToggleButton>
                </StackPanel>
            </Border>

        </Grid>
    </DockPanel>
</Window>
