                                            <TextBlock Text="FUNC 2" FontFamily="Segoe UI" FontSize="9"
                                                       Foreground="{DynamicResource ThemeSpecialCharLabelFg}" HorizontalAlignment="Center"
                                                       Margin="0,2,0,0"/>
                                        </StackPanel>
                                        <TextBlock Text="F2" FontFamily="Segoe UI" FontSize="8" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource ThemeSpecialCharShortcutFg}"
                                                   HorizontalAlignment="Left" VerticalAlignment="Bottom"
                                                   Margin="3,0,0,2"/>
                                    </Grid>
                                </Button>
                                <!-- F3 — PETSCII 134. Shift+F3 inserts this only when the Find bar is closed;
                                     while it's open, Shift+F3 does Find Previous instead. -->
                                <Button Style="{StaticResource SpecialCharButtonStyle}"
                                        Tag="134" Click="SpecialChar_Click"
                                        ToolTip="Function 3: Shift+F3; CHR$(134)">
                                    <Grid Width="58" Height="54">
                                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Border Background="{DynamicResource ThemePanelHeaderBg}" CornerRadius="2" Padding="6,2,6,2">
                                                <TextBlock Text="F3" FontFamily="Segoe UI" FontSize="14" FontWeight="Bold"
                                                           Foreground="{DynamicResource ThemePanelHeaderFg}" HorizontalAlignment="Center"/>
                                            </Border>
                                            <TextBlock Text="FUNC 3" FontFamily="Segoe UI" FontSize="9"
                                                       Foreground="{DynamicResource ThemeSpecialCharLabelFg}" HorizontalAlignment="Center"
                                                       Margin="0,2,0,0"/>
                                        </StackPanel>
                                        <TextBlock Text="F3" FontFamily="Segoe UI" FontSize="8" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource ThemeSpecialCharShortcutFg}"
                                                   HorizontalAlignment="Left" VerticalAlignment="Bottom"
                                                   Margin="3,0,0,2"/>
                                    </Grid>
                                </Button>
                                <!-- F4 — PETSCII 138 -->
                                <Button Style="{StaticResource SpecialCharButtonStyle}"
                                        Tag="138" Click="SpecialChar_Click"
                                        ToolTip="Function 4: Shift+F4; CHR$(138)">
                                    <Grid Width="58" Height="54">
                                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Border Background="{DynamicResource ThemePanelHeaderBg}" CornerRadius="2" Padding="6,2,6,2">
                                                <TextBlock Text="F4" FontFamily="Segoe UI" FontSize="14" FontWeight="Bold"
                                                           Foreground="{DynamicResource ThemePanelHeaderFg}" HorizontalAlignment="Center"/>
                                            </Border>
                                            <TextBlock Text="FUNC 4" FontFamily="Segoe UI" FontSize="9"
                                                       Foreground="{DynamicResource ThemeSpecialCharLabelFg}" HorizontalAlignment="Center"
                                                       Margin="0,2,0,0"/>
                                        </StackPanel>
                                        <TextBlock Text="F4" FontFamily="Segoe UI" FontSize="8" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource ThemeSpecialCharShortcutFg}"
                                                   HorizontalAlignment="Left" VerticalAlignment="Bottom"
                                                   Margin="3,0,0,2"/>
                                    </Grid>
                                </Button>
                                <!-- F5 — PETSCII 135 -->
                                <Button Style="{StaticResource SpecialCharButtonStyle}"
                                        Tag="135" Click="SpecialChar_Click"
                                        ToolTip="Function 5: Shift+F5; CHR$(135)">
                                    <Grid Width="58" Height="54">
                                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Border Background="{DynamicResource ThemePanelHeaderBg}" CornerRadius="2" Padding="6,2,6,2">
                                                <TextBlock Text="F5" FontFamily="Segoe UI" FontSize="14" FontWeight="Bold"
                                                           Foreground="{DynamicResource ThemePanelHeaderFg}" HorizontalAlignment="Center"/>
                                            </Border>
                                            <TextBlock Text="FUNC 5" FontFamily="Segoe UI" FontSize="9"
                                                       Foreground="{DynamicResource ThemeSpecialCharLabelFg}" HorizontalAlignment="Center"
                                                       Margin="0,2,0,0"/>
                                        </StackPanel>
                                        <TextBlock Text="F5" FontFamily="Segoe UI" FontSize="8" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource ThemeSpecialCharShortcutFg}"
                                                   HorizontalAlignment="Left" VerticalAlignment="Bottom"
                                                   Margin="3,0,0,2"/>
                                    </Grid>
                                </Button>
                                <!-- F6 — PETSCII 139 -->
                                <Button Style="{StaticResource SpecialCharButtonStyle}"
                                        Tag="139" Click="SpecialChar_Click"
                                        ToolTip="Function 6: Shift+F6; CHR$(139)">
                                    <Grid Width="58" Height="54">
                                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Border Background="{DynamicResource ThemePanelHeaderBg}" CornerRadius="2" Padding="6,2,6,2">
                                                <TextBlock Text="F6" FontFamily="Segoe UI" FontSize="14" FontWeight="Bold"
                                                           Foreground="{DynamicResource ThemePanelHeaderFg}" HorizontalAlignment="Center"/>
                                            </Border>
                                            <TextBlock Text="FUNC 6" FontFamily="Segoe UI" FontSize="9"
                                                       Foreground="{DynamicResource ThemeSpecialCharLabelFg}" HorizontalAlignment="Center"
                                                       Margin="0,2,0,0"/>
                                        </StackPanel>
                                        <TextBlock Text="F6" FontFamily="Segoe UI" FontSize="8" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource ThemeSpecialCharShortcutFg}"
                                                   HorizontalAlignment="Left" VerticalAlignment="Bottom"
                                                   Margin="3,0,0,2"/>
                                    </Grid>
                                </Button>
                                <!-- F7 — PETSCII 136 -->
                                <Button Style="{StaticResource SpecialCharButtonStyle}"
                                        Tag="136" Click="SpecialChar_Click"
                                        ToolTip="Function 7: Shift+F7; CHR$(136)">
                                    <Grid Width="58" Height="54">
                                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Border Background="{DynamicResource ThemePanelHeaderBg}" CornerRadius="2" Padding="6,2,6,2">
