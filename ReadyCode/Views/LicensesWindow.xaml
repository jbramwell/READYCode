<Window x:Class="ReadyCode.Views.LicensesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="ThreeDBorderWindow"
        ResizeMode="NoResize"
        Title="Third-Party Licenses"
        Background="{DynamicResource ThemeSettingsContentBg}"
        Width="560" Height="520"
        MinWidth="420" MinHeight="320"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <Window.Resources>
        <Style x:Key="CloseDialogButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource ThemeSettingsAccent}"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20,18,20,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Third-Party Licenses"
                   FontSize="18"
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource ThemeSettingsLabelFg}"
                   Margin="0,0,0,14"/>

        <Border Grid.Row="1"
                Background="{DynamicResource ThemeSettingsInputBg}"
                BorderBrush="{DynamicResource ThemeSettingsInputBorder}"
                BorderThickness="1"
                CornerRadius="4">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12">
                <TextBlock x:Name="LicenseText"
                           FontFamily="Consolas"
                           FontSize="12"
                           Foreground="{DynamicResource ThemeSettingsDescFg}"
                           TextWrapping="Wrap"/>
            </ScrollViewer>
        </Border>

        <Button Grid.Row="2"
                Style="{StaticResource CloseDialogButton}"
                Content="OK" Width="90" Height="30"
                HorizontalAlignment="Right"
                Margin="0,16,0,0"
                IsDefault="True"
                Click="CloseButton_Click"/>
    </Grid>

</Window>
