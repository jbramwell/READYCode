<Window x:Class="ReadyCode.Views.AboutC64UWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="ThreeDBorderWindow"
        AllowsTransparency="False"
        Background="Transparent"
        Width="380" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Title="About My Commodore 64 Ultimate">

    <Window.Resources>
        <Style x:Key="TitleBarCloseButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeSettingsBreadcrumbFg}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#E81123"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#C50F1F"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InfoLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeSettingsDescFg}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="InfoValue" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeSettingsLabelFg}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
        </Style>

        <Style x:Key="OkButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource ThemeSettingsAccent}"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="{DynamicResource ThemeSettingsContentBg}"
            BorderBrush="{DynamicResource ThemeSettingsDivider}"
            BorderThickness="1"
            CornerRadius="4">
        <DockPanel>
            <!-- Content -->
            <StackPanel Margin="20,16,20,20">

                <!-- Info grid -->
                <Grid Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="28"/>
                        <RowDefinition Height="28"/>
                        <RowDefinition x:Name="CoreVersionRow" Height="28"/>
                        <RowDefinition Height="1"/>
                        <RowDefinition Height="28"/>
                        <RowDefinition x:Name="UniqueIdRow" Height="28"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource InfoLabel}" Text="Firmware version"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" Style="{StaticResource InfoValue}" Text="{Binding FirmwareVersion}"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource InfoLabel}" Text="FPGA version"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" Style="{StaticResource InfoValue}" Text="{Binding FpgaVersion}"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource InfoLabel}" Text="Core version"
                               Visibility="{Binding CoreVersionVisibility}"/>
                    <TextBlock Grid.Row="2" Grid.Column="1" Style="{StaticResource InfoValue}" Text="{Binding CoreVersion}"
                               Visibility="{Binding CoreVersionVisibility}"/>

                    <!-- Divider -->
                    <Rectangle Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2"
                               Fill="{DynamicResource ThemeSettingsDivider}"
                               Margin="0,4"/>

                    <TextBlock Grid.Row="4" Grid.Column="0" Style="{StaticResource InfoLabel}" Text="Hostname"/>
                    <TextBlock Grid.Row="4" Grid.Column="1" Style="{StaticResource InfoValue}" Text="{Binding Hostname}"/>

                    <TextBlock Grid.Row="5" Grid.Column="0" Style="{StaticResource InfoLabel}" Text="Unique ID"
                               Visibility="{Binding UniqueIdVisibility}"/>
                    <TextBlock Grid.Row="5" Grid.Column="1" Style="{StaticResource InfoValue}" Text="{Binding UniqueId}"
                               Visibility="{Binding UniqueIdVisibility}"/>
                </Grid>

                <!-- Errors (shown only when present) -->
                <TextBlock Text="{Binding ErrorText}"
                           Visibility="{Binding ErrorVisibility}"
                           FontSize="12"
                           Foreground="#CC3333"
                           TextWrapping="Wrap"
                           Margin="0,0,0,12"/>

                <Button Style="{StaticResource OkButton}"
                        Content="OK" Width="90" Height="30"
                        HorizontalAlignment="Center"
                        IsDefault="True"
                        Click="CloseButton_Click"/>
            </StackPanel>

        </DockPanel>
    </Border>

</Window>
