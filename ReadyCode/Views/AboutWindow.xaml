<Window x:Class="ReadyCode.Views.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="ThreeDBorderWindow"
        Title="About READYCode"
        AllowsTransparency="False"
        Background="Transparent"
        Width="520" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <Window.Resources>

        <Style x:Key="TitleBarCloseButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeSettingsBreadcrumbFg}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#E81123"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#C50F1F"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="OkButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource ThemeSettingsAccent}"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource ThemeSettingsBtnBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeSettingsLabelFg}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeSettingsBtnBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource ThemeSettingsBtnHoverBg}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Border Background="{DynamicResource ThemeSettingsContentBg}"
            BorderBrush="{DynamicResource ThemeSettingsDivider}"
            BorderThickness="1"
            CornerRadius="4">
        <DockPanel>

            <!-- Title bar -->

            <!-- Content -->
            <DockPanel Margin="20,18,20,20">

                <!-- Logo image (left) -->
                <Border DockPanel.Dock="Left"
                        Width="172" Height="172"
                        BorderThickness="1"
                        BorderBrush="{DynamicResource ThemeSettingsDivider}"
                        Margin="0,0,20,0">
                    <Image Source="/ReadyCode;component/Assets/READYCode-03-wht-1024x1024.png"
                           Stretch="Uniform"
                           RenderOptions.BitmapScalingMode="HighQuality"
                           Margin="8"/>
                </Border>

                <!-- Right column: text + OK button -->
                <DockPanel>

                    <!-- Licenses + OK buttons pinned to bottom -->
                    <Grid DockPanel.Dock="Bottom" Margin="0,16,0,0">
                        <Button Style="{StaticResource SecondaryButton}"
                                Content="Licenses..." Width="100" Height="30"
                                HorizontalAlignment="Left"
                                Click="LicensesButton_Click"/>
                        <Button Style="{StaticResource OkButton}"
                                Content="OK" Width="90" Height="30"
                                HorizontalAlignment="Right"
                                IsDefault="True"
                                Click="CloseButton_Click"/>
                    </Grid>

                    <!-- Text -->
                    <StackPanel VerticalAlignment="Top">

                        <TextBlock Text="{Binding AppTitle}"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource ThemeSettingsLabelFg}"
                                   Margin="0,0,0,14"/>

                        <TextBlock Text="A BASIC code editor for the Commodore 64 Ultimate."
                                   FontSize="13"
                                   Foreground="{DynamicResource ThemeSettingsDescFg}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,14"/>

                        <TextBlock Text="© 2026 Moonspace Labs, LLC"
                                   FontSize="13"
                                   Foreground="{DynamicResource ThemeSettingsDescFg}"/>

                    </StackPanel>
                </DockPanel>

            </DockPanel>

        </DockPanel>
    </Border>

</Window>
