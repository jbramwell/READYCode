<Window x:Class="ReadyCode.Views.MinifyWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Minify Code"
        Width="440"
        SizeToContent="Height"
        WindowStyle="ThreeDBorderWindow"
        AllowsTransparency="False"
        Background="Transparent"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <Window.Resources>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground"       Value="{DynamicResource ThemeSettingsLabelFg}"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal"
                                    Margin="{TemplateBinding Margin}">
                            <Border x:Name="Box"
                                    Width="14" Height="14"
                                    VerticalAlignment="Center"
                                    Background="{DynamicResource ThemeSettingsInputBg}"
                                    BorderBrush="{DynamicResource ThemeSettingsInputBorder}"
                                    BorderThickness="1.5"
                                    CornerRadius="2">
                                <Path x:Name="Check"
                                      Data="M 2 6 L 5 10 L 12 2"
                                      Stroke="White"
                                      StrokeThickness="1.8"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      Visibility="Collapsed"/>
                            </Border>
                            <ContentPresenter Margin="8,0,0,0"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Check" Property="Visibility"  Value="Visible"/>
                                <Setter TargetName="Box"   Property="Background"  Value="{DynamicResource ThemeSettingsAccent}"/>
                                <Setter TargetName="Box"   Property="BorderBrush" Value="{DynamicResource ThemeSettingsAccent}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Box" Property="BorderBrush" Value="{DynamicResource ThemeSettingsAccent}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Background"       Value="{DynamicResource ThemeSettingsBtnBg}"/>
            <Setter Property="Foreground"       Value="{DynamicResource ThemeSettingsLabelFg}"/>
            <Setter Property="BorderBrush"      Value="{DynamicResource ThemeSettingsBtnBorder}"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="Padding"          Value="12,4"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"  Value="{DynamicResource ThemeSettingsBtnHoverBg}"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource ThemeSettingsTreeSelectedBg}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ThemeSettingsTreeSelectedBg}"/>
                            </Trigger>
                            <Trigger Property="IsDefault" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource ThemeSettingsTreeSelectedBg}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TitleBarCloseButton" TargetType="Button">
            <Setter Property="Foreground"       Value="{DynamicResource ThemeSettingsLabelFg}"/>
            <Setter Property="Background"       Value="Transparent"/>
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#E81123"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#C50F1F"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Border Background="{DynamicResource ThemeSettingsContentBg}"
            BorderBrush="{DynamicResource ThemeSettingsDivider}"
            BorderThickness="1">
        <DockPanel>

            <!-- Custom title bar -->
            <Border DockPanel.Dock="Top"
                    Background="{DynamicResource ThemeSettingsFooterBg}"
                    BorderBrush="{DynamicResource ThemeSettingsFooterBorder}"
                    BorderThickness="0,0,0,1"
                    Height="34"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <DockPanel>
                    <Button DockPanel.Dock="Right"
                            Style="{StaticResource TitleBarCloseButton}"
                            Width="46"
                            FontSize="14"
                            Content="✕"
                            Click="CloseButton_Click"/>
                    <TextBlock Text="READYCode — Minify Code"
                               FontSize="13"
                               VerticalAlignment="Center"
                               Margin="12,0,0,0"
                               Foreground="{DynamicResource ThemeSettingsBreadcrumbFg}"/>
                </DockPanel>
            </Border>

            <!-- Footer with Minify / Cancel buttons -->
            <Border DockPanel.Dock="Bottom"
                    BorderBrush="{DynamicResource ThemeSettingsFooterBorder}"
                    BorderThickness="0,1,0,0"
                    Background="{DynamicResource ThemeSettingsFooterBg}">
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="12,8">
                    <Button Content="Minify"
                            Width="80"
                            Margin="0,0,8,0"
                            IsDefault="True"
                            Click="Minify_Click"/>
                    <Button Content="Cancel"
                            Width="80"
                            IsCancel="True"/>
                </StackPanel>
            </Border>

            <!-- Options -->
            <StackPanel Margin="24,18,24,20">
                <TextBlock Text="Select minification options to apply:"
                           FontSize="12"
                           Foreground="{DynamicResource ThemeSettingsLabelFg}"
                           Margin="0,0,0,14"/>

                <CheckBox Content="Remove whitespace"
                          IsChecked="{Binding RemoveWhitespace}"
                          Margin="0,0,0,10"/>
                <CheckBox Content="Replace 0 with ."
                          IsChecked="{Binding Replace0WithPeriod}"
                          Margin="0,0,0,10"/>
                <CheckBox Content="Use scientific notation"
                          IsChecked="{Binding UseScientificNotation}"
                          Margin="0,0,0,10"/>
                <CheckBox Content="Remove comments (REM statements)"
                          IsChecked="{Binding RemoveComments}"
                          Margin="0,0,0,10"/>
                <CheckBox Content="Simplify NEXT statements"
                          IsChecked="{Binding SimplifyNextStatements}"
                          Margin="0,0,0,10"/>
                <CheckBox Content="Renumber line numbers and remove zero padding"
                          IsChecked="{Binding RenumberLines}"/>
            </StackPanel>

        </DockPanel>
    </Border>

</Window>
