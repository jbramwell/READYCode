<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Menu Bar -->
    <SolidColorBrush x:Key="ThemeMenuBg"        Color="#F0F0F0"/>
    <SolidColorBrush x:Key="ThemeMenuFg"        Color="#1F1F1F"/>

    <!-- Menu Items / Dropdowns -->
    <SolidColorBrush x:Key="ThemeMenuItemBg"          Color="#FFFFFF"/>
    <SolidColorBrush x:Key="ThemeMenuItemFg"          Color="#1F1F1F"/>
    <SolidColorBrush x:Key="ThemeMenuItemHoverBg"     Color="#CCE4F7"/>
    <SolidColorBrush x:Key="ThemeMenuItemHoverFg"     Color="#1F1F1F"/>
    <SolidColorBrush x:Key="ThemeMenuItemHoverBorder" Color="#0066CC"/>
    <SolidColorBrush x:Key="ThemeMenuItemDisabledFg"  Color="#AAAAAA"/>
    <SolidColorBrush x:Key="ThemeMenuItemBorder"      Color="#D4D4D4"/>

    <!-- Folder Explorer Panel -->
    <SolidColorBrush x:Key="ThemeFolderExplorerBg"           Color="#F3F3F3"/>
    <SolidColorBrush x:Key="ThemeFolderExplorerHeaderBg"     Color="#E8E8E8"/>
    <SolidColorBrush x:Key="ThemeFolderExplorerHeaderBorder" Color="#D0D0D0"/>

    <!-- Splitters -->
    <SolidColorBrush x:Key="ThemeSplitter" Color="#D0D0D0"/>

    <!-- Tab Bar -->
    <SolidColorBrush x:Key="ThemeTabBarBg"      Color="#F3F3F3"/>
    <SolidColorBrush x:Key="ThemeTabBorder"     Color="#E0E0E0"/>
    <SolidColorBrush x:Key="ThemeTabActiveBg"   Color="#FFFFFF"/>
    <SolidColorBrush x:Key="ThemeTabInactiveBg" Color="#ECECEC"/>
    <SolidColorBrush x:Key="ThemeTabItemBorder" Color="#D4D4D4"/>
    <SolidColorBrush x:Key="ThemeTabActiveFg"   Color="#1F1F1F"/>
    <SolidColorBrush x:Key="ThemeTabInactiveFg" Color="#6B6B6B"/>

    <!-- File Tree Items -->
    <SolidColorBrush x:Key="ThemeFileFg"                 Color="#333333"/>
    <SolidColorBrush x:Key="ThemeFileSelectedBg"         Color="#CCE4F7"/>
    <SolidColorBrush x:Key="ThemeFileInactiveSelectedBg" Color="#E4E6F0"/>

    <!-- Folder Explorer Icons & Buttons -->
    <SolidColorBrush x:Key="ThemeFolderExplorerIconFg"     Color="#616161"/>
    <SolidColorBrush x:Key="ThemeFolderExplorerHoverBg"    Color="#E8F0FE"/>
    <SolidColorBrush x:Key="ThemeFolderExplorerBtnHover"   Color="#D0D0D0"/>
    <SolidColorBrush x:Key="ThemeFolderExplorerBtnPressed" Color="#BBBBBB"/>

    <!-- C64U Explorer file-type badges: blue for disk images (storage), orange for machine
         language (caution - not editable/verified), green for confirmed-runnable BASIC (go/ready),
         purple for 6502 assembly source -->
    <SolidColorBrush x:Key="ThemeBadgeDiskBg" Color="#0066CC"/>
    <SolidColorBrush x:Key="ThemeBadgeDiskFg" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="ThemeBadgeMlBg"   Color="#CC6600"/>
    <SolidColorBrush x:Key="ThemeBadgeMlFg"   Color="#FFFFFF"/>
    <SolidColorBrush x:Key="ThemeBadgePrgBg"  Color="#1E7B34"/>
    <SolidColorBrush x:Key="ThemeBadgePrgFg"  Color="#FFFFFF"/>
    <SolidColorBrush x:Key="ThemeBadgeAsmBg"  Color="#7B2FA3"/>
    <SolidColorBrush x:Key="ThemeBadgeAsmFg"  Color="#FFFFFF"/>

    <!-- Status Bar -->
    <SolidColorBrush x:Key="ThemeStatusBarBg"     Color="#F0F0F0"/>
    <SolidColorBrush x:Key="ThemeStatusBarFg"     Color="#333333"/>
    <SolidColorBrush x:Key="ThemeStatusWarningBg" Color="#FFDD57"/>
    <SolidColorBrush x:Key="ThemeStatusWarningFg" Color="#000000"/>
    <SolidColorBrush x:Key="ThemeStatusErrorBg"   Color="#C50F1F"/>
    <SolidColorBrush x:Key="ThemeStatusErrorFg"   Color="#FFFFFF"/>

    <!-- Activity Bar -->
    <SolidColorBrush x:Key="ThemeActivityBarIndicator" Color="#0098FF"/>

    <!-- Editor -->
    <SolidColorBrush x:Key="ThemeEditorBg"                Color="#FFFFFF"/>
    <SolidColorBrush x:Key="ThemeEditorFg"                Color="#000000"/>
    <SolidColorBrush x:Key="ThemeEditorLineNumberFg"      Color="#808080"/>
    <SolidColorBrush x:Key="ThemeEditorKeywordFg"         Color="#0000FF"/>
    <SolidColorBrush x:Key="ThemeEditorCommentFg"         Color="#2d8a3e"/>
    <SolidColorBrush x:Key="ThemeEditorNumberLiteralFg"   Color="#008080"/>
    <SolidColorBrush x:Key="ThemeEditorStringFg"          Color="#A31515"/>
    <SolidColorBrush x:Key="ThemeEditorGuideLineFg"       Color="#FF0000"/>
    <SolidColorBrush x:Key="ThemeEditorCurrentLineBorder" Color="#BBBBBB"/>
    <SolidColorBrush x:Key="ThemeEditorErrorSquiggle"     Color="#E51400"/>

    <!-- Find / Replace Highlighting -->
    <SolidColorBrush x:Key="ThemeFindMatchBg"   Color="#FFFFB3"/>
    <SolidColorBrush x:Key="ThemeFindMatchFg"   Color="#000000"/>
    <SolidColorBrush x:Key="ThemeFindCurrentBg" Color="#FFB300"/>
    <SolidColorBrush x:Key="ThemeFindCurrentFg" Color="#000000"/>

    <!-- Settings Window -->
    <SolidColorBrush x:Key="ThemeSettingsContentBg"      Color="#FFFFFF"/>
    <SolidColorBrush x:Key="ThemeSettingsTreeBg"         Color="#F3F3F3"/>
    <SolidColorBrush x:Key="ThemeSettingsTreeFg"         Color="#1F1F1F"/>
    <SolidColorBrush x:Key="ThemeSettingsTreeHoverBg"    Color="#E8E8E8"/>
    <SolidColorBrush x:Key="ThemeSettingsTreeSelectedBg" Color="#CCE4F7"/>
    <SolidColorBrush x:Key="ThemeSettingsTreeSelectedFg" Color="#1F1F1F"/>
    <SolidColorBrush x:Key="ThemeSettingsDivider"        Color="#D4D4D4"/>
    <SolidColorBrush x:Key="ThemeSettingsFooterBg"       Color="#F5F5F5"/>
    <SolidColorBrush x:Key="ThemeSettingsFooterBorder"   Color="#D0D0D0"/>
    <SolidColorBrush x:Key="ThemeSettingsBreadcrumbFg"   Color="#1F1F1F"/>
    <SolidColorBrush x:Key="ThemeSettingsLabelFg"        Color="#1F1F1F"/>
    <SolidColorBrush x:Key="ThemeSettingsDescFg"         Color="#737373"/>
    <SolidColorBrush x:Key="ThemeSettingsRowBorder"      Color="#E8E8E8"/>
    <SolidColorBrush x:Key="ThemeSettingsInputBg"        Color="#FFFFFF"/>
    <SolidColorBrush x:Key="ThemeSettingsInputBorder"    Color="#AAAAAA"/>
    <SolidColorBrush x:Key="ThemeSettingsBtnBg"          Color="#E8E8E8"/>
    <SolidColorBrush x:Key="ThemeSettingsBtnHoverBg"     Color="#CCE4F7"/>
    <SolidColorBrush x:Key="ThemeSettingsBtnBorder"      Color="#AAAAAA"/>
    <SolidColorBrush x:Key="ThemeSettingsAccent"         Color="#0066CC"/>

    <!-- Quick Keys Cards -->
    <SolidColorBrush x:Key="ThemeCardBg" Color="#FFFFFF"/>

    <!-- Quick Keys Panel -->
    <SolidColorBrush x:Key="ThemeSpecialCharIconFg"         Color="#1F1F1F"/>
    <SolidColorBrush x:Key="ThemeSpecialCharLabelFg"        Color="#555555"/>
    <SolidColorBrush x:Key="ThemeSpecialCharShortcutFg"     Color="#AAAAAA"/>
    <SolidColorBrush x:Key="ThemeSpecialCharBtnHoverBg"     Color="#E8F0FE"/>
    <SolidColorBrush x:Key="ThemeSpecialCharBtnHoverBorder" Color="#0066CC"/>
    <SolidColorBrush x:Key="ThemeSpecialCharBtnPressedBg"   Color="#CCE4F7"/>

    <!-- PETSCII Reference Panel -->
    <SolidColorBrush x:Key="ThemePetsciiRowEvenBg"  Color="#FFFFFF"/>
    <SolidColorBrush x:Key="ThemePetsciiRowOddBg"   Color="#F5F5F5"/>
    <SolidColorBrush x:Key="ThemePetsciiRowHoverBg" Color="#CCE4F7"/>
    <SolidColorBrush x:Key="ThemePetsciiSeparator"  Color="#E0E0E0"/>
    <SolidColorBrush x:Key="ThemePetsciiHeaderBg"   Color="#D8D8D8"/>
    <SolidColorBrush x:Key="ThemePetsciiCodeFg"     Color="#444444"/>
    <SolidColorBrush x:Key="ThemePetsciiNoteBg"     Color="#F0F0F0"/>
    <SolidColorBrush x:Key="ThemePetsciiGlyphFg"    Color="#1F1F1F"/>
    <SolidColorBrush x:Key="ThemePanelHeaderBg"     Color="#1A1A1A"/>
    <SolidColorBrush x:Key="ThemePanelHeaderFg"     Color="#FFFFFF"/>

</ResourceDictionary>
