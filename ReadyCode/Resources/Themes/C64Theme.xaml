<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Pepto-pastel palette, built entirely from the editor's background (#352879) and
         foreground (#6C5EB5), plus a few darker/lighter steps along the same hue for hover,
         selection, and hierarchy:
           D0 #1F1850 (deepest)  D1 #352879 (= editor bg)  D2 #4A3D95  D3 #7166AE
           L1 #6C5EB5 (= editor fg)  L2 #9B90D2  L3 #C7C0E8 (lightest)
         Most chrome (menus, tabs, status bar, dialogs) stays in the dark D-family, matching
         the editor. The Explorer/PETSCII/Quick Keys/Basic Keywords/Music Notes side panels use
         the lighter L-family with dark (D1) text, for a bit of pastel variety. -->

    <!-- Menu Bar -->
    <SolidColorBrush x:Key="ThemeMenuBg"        Color="#352879"/>
    <SolidColorBrush x:Key="ThemeMenuFg"        Color="#FFFFFF"/>

    <!-- Menu Items / Dropdowns -->
    <SolidColorBrush x:Key="ThemeMenuItemBg"          Color="#4A3D95"/>
    <SolidColorBrush x:Key="ThemeMenuItemFg"          Color="#FFFFFF"/>
    <SolidColorBrush x:Key="ThemeMenuItemHoverBg"     Color="#7166AE"/>
    <SolidColorBrush x:Key="ThemeMenuItemHoverFg"     Color="#FFFFFF"/>
    <SolidColorBrush x:Key="ThemeMenuItemHoverBorder" Color="#6C5EB5"/>
    <SolidColorBrush x:Key="ThemeMenuItemDisabledFg"  Color="#7166AE"/>
    <SolidColorBrush x:Key="ThemeMenuItemBorder"      Color="#352879"/>

    <!-- Folder Explorer Panel (also the shared background for the PETSCII, Quick Keys, Basic
         Keywords, and Music Notes side panels) -->
    <SolidColorBrush x:Key="ThemeFolderExplorerBg"           Color="#6C5EB5"/>
    <SolidColorBrush x:Key="ThemeFolderExplorerHeaderBg"     Color="#9B90D2"/>
    <SolidColorBrush x:Key="ThemeFolderExplorerHeaderBorder" Color="#352879"/>

    <!-- Splitters -->
    <SolidColorBrush x:Key="ThemeSplitter" Color="#4A3D95"/>

    <!-- Tab Bar -->
    <SolidColorBrush x:Key="ThemeTabBarBg"      Color="#352879"/>
    <SolidColorBrush x:Key="ThemeTabBorder"     Color="#4A3D95"/>
    <SolidColorBrush x:Key="ThemeTabActiveBg"   Color="#352879"/>
    <SolidColorBrush x:Key="ThemeTabInactiveBg" Color="#4A3D95"/>
    <SolidColorBrush x:Key="ThemeTabItemBorder" Color="#352879"/>
    <SolidColorBrush x:Key="ThemeTabActiveFg"   Color="#FFFFFF"/>
    <SolidColorBrush x:Key="ThemeTabInactiveFg" Color="#7166AE"/>

    <!-- File Tree Items -->
    <SolidColorBrush x:Key="ThemeFileFg"                 Color="#352879"/>
    <SolidColorBrush x:Key="ThemeFileSelectedBg"         Color="#C7C0E8"/>
    <SolidColorBrush x:Key="ThemeFileInactiveSelectedBg" Color="#9B90D2"/>

    <!-- Folder Explorer Icons & Buttons -->
    <SolidColorBrush x:Key="ThemeFolderExplorerIconFg"     Color="#352879"/>
    <SolidColorBrush x:Key="ThemeFolderExplorerHoverBg"    Color="#9B90D2"/>
    <SolidColorBrush x:Key="ThemeFolderExplorerBtnHover"   Color="#6C5EB5"/>
    <SolidColorBrush x:Key="ThemeFolderExplorerBtnPressed" Color="#7166AE"/>

    <!-- C64U Explorer file-type badges: three more colors pulled from the authentic Pepto VIC-II
         palette (see the header comment), the same source as this theme's whole palette - Blue
         for disk images, Orange for machine language (caution), Green for confirmed-runnable
         BASIC (go/ready), Purple for 6502 assembly source, same reasoning as the other themes
         but using real C64 hardware colors. -->
    <SolidColorBrush x:Key="ThemeBadgeDiskBg" Color="#352879"/>
    <SolidColorBrush x:Key="ThemeBadgeDiskFg" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="ThemeBadgeMlBg"   Color="#6F4F25"/>
    <SolidColorBrush x:Key="ThemeBadgeMlFg"   Color="#FFFFFF"/>
    <SolidColorBrush x:Key="ThemeBadgePrgBg"  Color="#588D43"/>
    <SolidColorBrush x:Key="ThemeBadgePrgFg"  Color="#FFFFFF"/>
    <SolidColorBrush x:Key="ThemeBadgeAsmBg"  Color="#6F3D86"/>
    <SolidColorBrush x:Key="ThemeBadgeAsmFg"  Color="#FFFFFF"/>

    <!-- Status Bar -->
    <SolidColorBrush x:Key="ThemeStatusBarBg"     Color="#1F1850"/>
    <SolidColorBrush x:Key="ThemeStatusBarFg"     Color="#6C5EB5"/>
    <SolidColorBrush x:Key="ThemeStatusWarningBg" Color="#EEEE77"/>
    <SolidColorBrush x:Key="ThemeStatusWarningFg" Color="#000000"/>
    <SolidColorBrush x:Key="ThemeStatusErrorBg"   Color="#880000"/>
    <SolidColorBrush x:Key="ThemeStatusErrorFg"   Color="#FFFFFF"/>

    <!-- Activity Bar -->
    <SolidColorBrush x:Key="ThemeActivityBarIndicator" Color="#6C5EB5"/>

    <!-- Editor: matches the authentic C64 boot-screen palette (Blue background, Light Blue
         text) with a single uniform foreground color for all code, like real hardware. -->
    <SolidColorBrush x:Key="ThemeEditorBg"                Color="#352879"/>
    <SolidColorBrush x:Key="ThemeEditorFg"                Color="#6C5EB5"/>
    <SolidColorBrush x:Key="ThemeEditorLineNumberFg"      Color="#6C5EB5"/>
    <SolidColorBrush x:Key="ThemeEditorKeywordFg"         Color="#6C5EB5"/>
    <SolidColorBrush x:Key="ThemeEditorCommentFg"         Color="#6C5EB5"/>
    <SolidColorBrush x:Key="ThemeEditorNumberLiteralFg"   Color="#6C5EB5"/>
    <SolidColorBrush x:Key="ThemeEditorStringFg"          Color="#6C5EB5"/>
    <SolidColorBrush x:Key="ThemeEditorGuideLineFg"       Color="#3333AA"/>
    <SolidColorBrush x:Key="ThemeEditorCurrentLineBorder" Color="#3333CC"/>
    <SolidColorBrush x:Key="ThemeEditorErrorSquiggle"     Color="#FF4136"/>

    <!-- Hex Editor: selected-byte text, drawn on top of ThemeSettingsAccent rather than
         ThemeEditorBg (its background there while unselected). -->
    <SolidColorBrush x:Key="ThemeHexSelectedFg" Color="#FFFFFF"/>

    <!-- Find / Replace Highlighting -->
    <SolidColorBrush x:Key="ThemeFindMatchBg"   Color="#EEEE77"/>
    <SolidColorBrush x:Key="ThemeFindMatchFg"   Color="#000000"/>
    <SolidColorBrush x:Key="ThemeFindCurrentBg" Color="#DD8855"/>
    <SolidColorBrush x:Key="ThemeFindCurrentFg" Color="#000000"/>

    <!-- Settings Window -->
    <SolidColorBrush x:Key="ThemeSettingsContentBg"      Color="#352879"/>
    <SolidColorBrush x:Key="ThemeSettingsTreeBg"         Color="#1F1850"/>
    <SolidColorBrush x:Key="ThemeSettingsTreeFg"         Color="#6C5EB5"/>
    <SolidColorBrush x:Key="ThemeSettingsTreeHoverBg"    Color="#4A3D95"/>
    <SolidColorBrush x:Key="ThemeSettingsTreeSelectedBg" Color="#7166AE"/>
    <SolidColorBrush x:Key="ThemeSettingsTreeSelectedFg" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="ThemeSettingsDivider"        Color="#4A3D95"/>
    <SolidColorBrush x:Key="ThemeSettingsFooterBg"       Color="#1F1850"/>
    <SolidColorBrush x:Key="ThemeSettingsFooterBorder"   Color="#4A3D95"/>
    <SolidColorBrush x:Key="ThemeSettingsBreadcrumbFg"   Color="#7166AE"/>
    <SolidColorBrush x:Key="ThemeSettingsLabelFg"        Color="#6C5EB5"/>
    <SolidColorBrush x:Key="ThemeSettingsDescFg"         Color="#7166AE"/>
    <SolidColorBrush x:Key="ThemeSettingsRowBorder"      Color="#4A3D95"/>
    <SolidColorBrush x:Key="ThemeSettingsInputBg"        Color="#1F1850"/>
    <SolidColorBrush x:Key="ThemeSettingsInputBorder"    Color="#7166AE"/>
    <SolidColorBrush x:Key="ThemeSettingsBtnBg"          Color="#4A3D95"/>
    <SolidColorBrush x:Key="ThemeSettingsBtnHoverBg"     Color="#7166AE"/>
    <SolidColorBrush x:Key="ThemeSettingsBtnBorder"      Color="#7166AE"/>
    <SolidColorBrush x:Key="ThemeSettingsAccent"         Color="#6C5EB5"/>

    <!-- Quick Keys Cards -->
    <SolidColorBrush x:Key="ThemeCardBg" Color="#9B90D2"/>

    <!-- Quick Keys Panel -->
    <SolidColorBrush x:Key="ThemeSpecialCharIconFg"         Color="#352879"/>
    <SolidColorBrush x:Key="ThemeSpecialCharLabelFg"        Color="#4A3D95"/>
    <SolidColorBrush x:Key="ThemeSpecialCharShortcutFg"     Color="#352879"/>
    <SolidColorBrush x:Key="ThemeSpecialCharBtnHoverBg"     Color="#C7C0E8"/>
    <SolidColorBrush x:Key="ThemeSpecialCharBtnHoverBorder" Color="#352879"/>
    <SolidColorBrush x:Key="ThemeSpecialCharBtnPressedBg"   Color="#6C5EB5"/>

    <!-- PETSCII Reference Panel -->
    <SolidColorBrush x:Key="ThemePetsciiRowEvenBg"  Color="#6C5EB5"/>
    <SolidColorBrush x:Key="ThemePetsciiRowOddBg"   Color="#9B90D2"/>
    <SolidColorBrush x:Key="ThemePetsciiRowHoverBg" Color="#9B90D2"/>
    <SolidColorBrush x:Key="ThemePetsciiSeparator"  Color="#352879"/>
    <SolidColorBrush x:Key="ThemePetsciiHeaderBg"   Color="#352879"/>
    <SolidColorBrush x:Key="ThemePetsciiCodeFg"     Color="#4A3D95"/>
    <SolidColorBrush x:Key="ThemePetsciiNoteBg"     Color="#9B90D2"/>
    <SolidColorBrush x:Key="ThemePetsciiGlyphFg"    Color="#352879"/>
    <SolidColorBrush x:Key="ThemePanelHeaderBg"     Color="#352879"/>
    <SolidColorBrush x:Key="ThemePanelHeaderFg"     Color="#FFFFFF"/>

</ResourceDictionary>
